---
import { getImage, Image, Picture } from "astro:assets";
import * as path from "node:path";
import type { ImageMetadata } from "astro";
import type { ImageFormat, ResponsiveImageLayout } from "@/types/config";
import {
	getFallbackFormat,
	getImageFormats,
	getImageQuality,
	shouldAddNoReferrer,
} from "@/utils/image-utils";
import { url } from "@/utils/url-utils";

interface Props {
	id?: string;
	src: string;
	class?: string;
	alt?: string;
	position?: string;
	basePath?: string;
	loading?: "lazy" | "eager";
	fetchpriority?: "high" | "low" | "auto";
	// 响应式图像属性
	layout?: ResponsiveImageLayout;
	usePicture?: boolean;
	formats?: ImageFormat[];
	widths?: number[];
	sizes?: string;
	quality?: number;
}

const {
	id,
	src,
	alt,
	position = "center",
	basePath = "/",
	loading = "lazy",
	fetchpriority = "auto",
	layout = "constrained",
	usePicture = true,
	formats = getImageFormats(),
	widths,
	sizes,
	quality = getImageQuality(),
} = Astro.props;

const fallbackFormat = getFallbackFormat();
const className = Astro.props.class;

const isLocal = !(
	src.startsWith("/") ||
	src.startsWith("http") ||
	src.startsWith("https") ||
	src.startsWith("data:")
);
const isPublic = src.startsWith("/");

// TODO temporary workaround for images dynamic import
// https://github.com/withastro/astro/issues/3373
let img: ImageMetadata | null = null;
if (isLocal) {
	const files = import.meta.glob<ImageMetadata>(
		"../../**/*.{png,jpg,jpeg,webp,avif,gif}",
		{
			import: "default",
		},
	);
	let normalizedPath = path
		.normalize(path.join("../../", basePath, src))
		.replace(/\\/g, "/");
	const file = files[normalizedPath];
	if (!file) {
		console.error(
			`\n[ERROR] Image file not found: ${normalizedPath.replace("../../", "src/")}`,
		);
	} else {
		img = await file();
	}
}

const imageClass = "w-full h-full object-cover";
const imageStyle = `object-position: ${position}`;

// 检查是否需要添加 referrerpolicy（仅对非本地图片）
const fullSrc = isPublic ? url(src) : src;
const referrerPolicy =
	!isLocal && shouldAddNoReferrer(fullSrc) ? "no-referrer" : undefined;

// 构建响应式图像属性
const responsiveProps = {
	...(layout && { layout }),
	...(widths && { widths }),
	...(sizes && { sizes }),
	...(quality && { quality }),
};

// 当 fetchpriority 不是 auto 时，需要使用原生 img 标签来确保属性正确传递
// 因为 Astro 的 <Picture> / <Image> 组件不会将 fetchpriority 传递到最终的 <img> 标签
const needsNativeImg = fetchpriority !== "auto";

// 预获取优化后的图片信息（用于原生 img 标签）
let optimizedImg: Awaited<ReturnType<typeof getImage>> | null = null;
let optimizedSources: { srcset: string; type: string }[] = [];
if (needsNativeImg && isLocal && img) {
	const originalSrc = img;
	// 获取各格式的优化图片
	optimizedSources = await Promise.all(
		formats.map(async (format) => {
			const optimized = await getImage({
				src: originalSrc,
				format,
				widths,
				...responsiveProps,
			});
			return {
				srcset: optimized.srcSet.attribute,
				type: `image/${format}`,
			};
		}),
	);
	// 获取 fallback 格式的优化图片
	optimizedImg = await getImage({
		src: originalSrc,
		format: fallbackFormat,
		widths,
		...responsiveProps,
	});
}
---
<div id={id} class:list={[className, 'overflow-hidden relative']}>
    <div class="transition absolute inset-0 dark:bg-black/10 pointer-events-none"></div>
    {isLocal && img && needsNativeImg && optimizedImg && (
        <picture>
            {optimizedSources.map((source) => (
                <source srcset={source.srcset} type={source.type} {...(sizes ? { sizes } : {})} />
            ))}
            <img
                src={optimizedImg.src}
                srcset={optimizedImg.srcSet.attribute}
                alt={alt || ""}
                class={imageClass}
                style={imageStyle}
                loading={loading}
                fetchpriority={fetchpriority}
                {...(optimizedImg.attributes.width ? { width: optimizedImg.attributes.width } : {})}
                {...(optimizedImg.attributes.height ? { height: optimizedImg.attributes.height } : {})}
            />
        </picture>
    )}
    {isLocal && img && !needsNativeImg && usePicture && (
        <Picture
            src={img}
            alt={alt || ""}
            class={imageClass}
            style={imageStyle}
            loading={loading}
            formats={formats}
            fallbackFormat={fallbackFormat}
            {...responsiveProps}
        />
    )}
    {isLocal && img && !needsNativeImg && !usePicture && (
        <Image
            src={img}
            alt={alt || ""}
            class={imageClass}
            style={imageStyle}
            loading={loading}
            {...responsiveProps}
        />
    )}
    {!isLocal && <img src={isPublic ? url(src) : src} alt={alt || ""} class={imageClass} style={imageStyle} loading={loading} fetchpriority={fetchpriority} referrerpolicy={referrerPolicy} />}
</div>
