---
import Icon from "@components/common/Icon.astro";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";

interface Props {
	id: string;
	name?: string;
	isCollapsed?: boolean;
	collapsedHeight?: string;
	useExpandedButtonSpacing?: boolean;
	class?: string;
	style?: string;
}
const {
	id,
	name,
	isCollapsed,
	collapsedHeight,
	useExpandedButtonSpacing = false,
	style,
} = Astro.props;
const className = Astro.props.class;
---
<widget-layout
    data-id={id}
    data-is-collapsed={String(isCollapsed)}
    data-use-expanded-button-spacing={String(useExpandedButtonSpacing)}
    class={"pb-4 section " + (className ?? "")}
    style={`--collapsedHeight: ${collapsedHeight || '0'}; ${style || ''}`}
>
    {name && (
        <div class="widget-title font-mono text-xs uppercase tracking-[0.2em] text-(--content-meta) mb-3 mt-4 px-4 flex items-center justify-between">
            <span class="widget-name">[ {name} ]</span>
            <slot name="title-icon" />
        </div>
    )}
    <div id={id} class:list={["collapse-wrapper px-4 overflow-hidden", {"collapsed": isCollapsed, "pt-4": !name}]}>
        <slot></slot>
    </div>
    {isCollapsed && <div class="expand-btn px-4 -mb-2">
        <button
            class="btn-line w-full h-9 text-sm"
            title={i18n(I18nKey.more)}
            aria-label={i18n(I18nKey.more)}
            data-show-more={i18n(I18nKey.more)}
            data-show-less={i18n(I18nKey.collapse)}
            data-expanded="false"
        >
            <div class="flex items-center justify-center gap-2">
                <Icon name="material-symbols:more-horiz" class="toggle-icon-more text-base" aria-hidden="true"></Icon>
                <Icon name="material-symbols:keyboard-arrow-up-rounded" class="toggle-icon-less hidden text-base" aria-hidden="true"></Icon>
                <span class="toggle-text">{i18n(I18nKey.more)}</span>
            </div>
        </button>
    </div>}
</widget-layout>

<!-- 样式已迁移至 src/styles/components/widget-layout.css -->

<script>
    class WidgetLayout extends HTMLElement {
        constructor() {
            super();

            // 鼠标边缘检测：判断鼠标最靠近哪条边，设置 data-hover-edge
            const EDGE_THRESHOLD = 0.28; // 边缘区域占比（0~0.5）
            const onMouseMove = (e: MouseEvent) => {
                const rect = this.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                const w = rect.width;
                const h = rect.height;

                // 计算到四条边的距离（归一化）
                const distTop    = y / h;
                const distBottom = (h - y) / h;
                const distLeft   = x / w;
                const distRight  = (w - x) / w;

                const minDist = Math.min(distTop, distBottom, distLeft, distRight);

                if (minDist > EDGE_THRESHOLD) {
                    // 鼠标在中间区域，不突出任何边
                    delete this.dataset.hoverEdge;
                } else if (minDist === distTop) {
                    this.dataset.hoverEdge = 'top';
                } else if (minDist === distBottom) {
                    this.dataset.hoverEdge = 'bottom';
                } else if (minDist === distLeft) {
                    this.dataset.hoverEdge = 'left';
                } else {
                    this.dataset.hoverEdge = 'right';
                }
            };
            const onMouseLeave = () => {
                delete this.dataset.hoverEdge;
            };
            this.addEventListener('mousemove', onMouseMove);
            this.addEventListener('mouseleave', onMouseLeave);

            if (this.dataset.isCollapsed !== "true")
                return;

            this.dataset.expanded = 'false';

            const id = this.dataset.id;
            const btn = this.querySelector('.expand-btn button') as HTMLButtonElement | null;
            const wrapper = this.querySelector(`#${id}`)

            if (!btn || !wrapper)
                return;

            const text = btn.querySelector('.toggle-text');
            const moreIcon = btn.querySelector('.toggle-icon-more');
            const lessIcon = btn.querySelector('.toggle-icon-less');
            const updateButtonState = (expanded: boolean) => {
                const label = expanded
                    ? btn.dataset.showLess || ''
                    : btn.dataset.showMore || '';

                btn.dataset.expanded = String(expanded);
                this.dataset.expanded = String(expanded);
                btn.title = label;
                btn.setAttribute('aria-label', label);
                if (text)
                    text.textContent = label;
                moreIcon?.classList.toggle('hidden', expanded);
                lessIcon?.classList.toggle('hidden', !expanded);
            };

            btn.addEventListener('click', () => {
                const expanded = btn.dataset.expanded === 'true';
                wrapper.classList.toggle('collapsed', expanded);
                updateButtonState(!expanded);
            });
        }
    }

    if (!customElements.get("widget-layout")) {
        customElements.define("widget-layout", WidgetLayout);
    }
</script>
