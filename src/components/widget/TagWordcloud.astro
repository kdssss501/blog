---
import { getTagUrl } from "@utils/url-utils";
import type { Tag } from "@/utils/content-utils";

interface Props {
	tags: Tag[];
}

const { tags } = Astro.props;

// 取全部标签
const topTags = tags;

const counts = topTags.map((t) => t.count);
const minCount = Math.min(...counts);
const maxCount = Math.max(...counts);
const minSize = 1.6;
const maxSize = 4.5;

function getFontSize(count: number): number {
	if (maxCount === minCount) return (minSize + maxSize) / 2;
	return (
		minSize + ((count - minCount) / (maxCount - minCount)) * (maxSize - minSize)
	);
}

const colors = [
	"var(--primary)",
	"#5470c6",
	"#91cc75",
	"#fac858",
	"#ee6666",
	"#73c0de",
	"#3ba272",
	"#fc8452",
	"#9a60b4",
	"#ea7ccc",
];

const chartData = topTags.map((t, i) => ({
	name: t.name,
	count: t.count,
	url: getTagUrl(t.name),
	size: getFontSize(t.count),
	color: colors[i % colors.length],
}));
---

<div
	id="tag-wordcloud-container"
	class="tag-wordcloud"
	data-tags={JSON.stringify(chartData)}
>
  <canvas id="tag-wordcloud-canvas" class="tag-wordcloud__canvas"></canvas>
</div>

<script is:inline>
(function() {
  function drawWordCloud(canvas, tags) {
    var container = canvas.parentElement;
    var dpr = window.devicePixelRatio || 1;
    var width = container.clientWidth;
    // 长方形：宽度的 75%，最小 450px
    var height = Math.max(450, Math.round(width * 0.75));

    canvas.width = width * dpr;
    canvas.height = height * dpr;
    canvas.style.width = width + "px";
    canvas.style.height = height + "px";

    var ctx = canvas.getContext("2d");
    ctx.scale(dpr, dpr);
    ctx.clearRect(0, 0, width, height);

    var isDark = document.documentElement.classList.contains("dark");
    var padding = 8;
    var placed = [];

    // 移动端缩小字体
    var isMobile = width < 640;
    var fontScale = isMobile ? 0.75 : 1;

    // 预打乱顺序，大标签优先放置
    var sorted = tags.slice().sort(function(a, b) { return b.size - a.size; });

    function hasCollision(x, y, w, h, arr) {
      for (var i = 0; i < arr.length; i++) {
        var p = arr[i];
        if (!(x + w < p.x || x > p.x + p.w || y + h < p.y || y > p.y + p.h)) return true;
      }
      return false;
    }

    function resolveColor(color, isDark) {
      if (color.indexOf("var(") === 0) {
        var m = color.match(/var\((--[^)]+)\)/);
        if (m && m[1]) {
          var v = getComputedStyle(document.documentElement).getPropertyValue(m[1]).trim();
          return v || (isDark ? "#fff" : "#333");
        }
      }
      return color;
    }

    function placeTag(x, y, w, h, tag, fontSize, isVertical, isDark, ctx, arr) {
      arr.push({ x: x, y: y, w: w, h: h });
      ctx.save();
      ctx.translate(x + w / 2, y + h / 2);
      if (isVertical) ctx.rotate(-Math.PI / 2);
      ctx.fillStyle = resolveColor(tag.color, isDark);
      ctx.globalAlpha = 0.85;
      ctx.font = "600 " + fontSize + "px sans-serif";
      ctx.textAlign = "center";
      ctx.textBaseline = "middle";
      ctx.fillText(tag.name, 0, 0);
      ctx.restore();
      return true;
    }

    var tagOrients = [];
    for (var ti = 0; ti < sorted.length; ti++) {
      var tag = sorted[ti];
      var fontSize = tag.size * 16 * fontScale;
      var isVertical = Math.random() > 0.55;
      tagOrients.push(isVertical);

      ctx.font = "600 " + fontSize + "px sans-serif";
      var textWidth = ctx.measureText(tag.name).width;
      var textHeight = fontSize * 1.2;

      var boxW = isVertical ? textHeight : textWidth + 6;
      var boxH = isVertical ? textWidth + 6 : textHeight;

      // 尝试放置：先随机，再网格扫描兜底
      var placedOk = false;
      var step = Math.max(8, Math.round(fontSize * 0.5));

      // 阶段1：随机尝试
      for (var attempt = 0; attempt < 300; attempt++) {
        var x = padding + Math.random() * (width - boxW - padding * 2);
        var y = padding + Math.random() * (height - boxH - padding * 2);
        if (x < 0 || y < 0 || x + boxW > width || y + boxH > height) continue;
        if (!hasCollision(x, y, boxW, boxH, placed)) {
          placedOk = placeTag(x, y, boxW, boxH, tag, fontSize, isVertical, isDark, ctx, placed);
          break;
        }
      }

      // 阶段2：网格扫描兜底
      if (!placedOk) {
        for (var gy = 0; gy <= height - boxH && !placedOk; gy += step) {
          for (var gx = 0; gx <= width - boxW && !placedOk; gx += step) {
            if (!hasCollision(gx, gy, boxW, boxH, placed)) {
              placedOk = placeTag(gx, gy, boxW, boxH, tag, fontSize, isVertical, isDark, ctx, placed);
            }
          }
        }
      }

    }

    // 存储绘制信息用于悬停重绘
    var drawData = [];
    for (var di = 0; di < placed.length; di++) {
      drawData.push({
        tag: sorted[di],
        box: placed[di],
        fontSize: sorted[di].size * 16 * fontScale,
        isVertical: tagOrients[di],
      });
    }

    function hitTest(mx, my) {
      for (var i = 0; i < placed.length; i++) {
        var p = placed[i];
        if (mx >= p.x && mx <= p.x + p.w && my >= p.y && my <= p.y + p.h) {
          return i;
        }
      }
      return -1;
    }

    function redrawAll(hoverIdx) {
      ctx.clearRect(0, 0, width, height);
      for (var i = 0; i < drawData.length; i++) {
        var d = drawData[i];
        var p = d.box;
        var fs = d.fontSize;
        var isHov = (i === hoverIdx);

        ctx.save();
        ctx.translate(p.x + p.w / 2, p.y + p.h / 2);
        if (d.isVertical) ctx.rotate(-Math.PI / 2);

        var fc = d.tag.color;
        if (fc.indexOf("var(") === 0) {
          var vn = fc.match(/var\((--[^)]+)\)/);
          if (vn && vn[1]) {
            fc = getComputedStyle(document.documentElement).getPropertyValue(vn[1]).trim();
            if (!fc) fc = isDark ? "#fff" : "#333";
          }
        }

        ctx.fillStyle = fc;
        ctx.globalAlpha = isHov ? 1 : 0.75;
        ctx.font = (isHov ? "800 " : "600 ") + (isHov ? fs * 1.15 : fs) + "px sans-serif";
        ctx.textAlign = "center";
        ctx.textBaseline = "middle";
        ctx.fillText(d.tag.name, 0, 0);

        // 悬停下划线
        if (isHov) {
          var tw = ctx.measureText(d.tag.name).width;
          ctx.strokeStyle = fc;
          ctx.lineWidth = 2;
          ctx.globalAlpha = 0.6;
          ctx.beginPath();
          ctx.moveTo(-tw / 2, fs * 0.45);
          ctx.lineTo(tw / 2, fs * 0.45);
          ctx.stroke();
        }

        ctx.restore();
      }
    }

    var lastHover = -1;

    canvas.onmousemove = function(e) {
      var rect = canvas.getBoundingClientRect();
      var mx = e.clientX - rect.left;
      var my = e.clientY - rect.top;
      var idx = hitTest(mx, my);
      canvas.style.cursor = idx >= 0 ? "pointer" : "default";
      if (idx !== lastHover) {
        lastHover = idx;
        redrawAll(idx);
      }
    };

    canvas.onmouseleave = function() {
      if (lastHover !== -1) {
        lastHover = -1;
        redrawAll(-1);
      }
      canvas.style.cursor = "default";
    };

    canvas.onclick = function(e) {
      var rect = canvas.getBoundingClientRect();
      var mx = e.clientX - rect.left;
      var my = e.clientY - rect.top;
      var idx = hitTest(mx, my);
      if (idx >= 0 && sorted[idx] && sorted[idx].url) {
        if (window.navigateToPage) {
          window.navigateToPage(sorted[idx].url);
        } else {
          window.location.href = sorted[idx].url;
        }
      }
    };
  }

  function initTagWordcloud() {
    var container = document.getElementById("tag-wordcloud-container");
    if (!container) return;

    var canvas = document.getElementById("tag-wordcloud-canvas");
    if (!canvas) return;

    var rawData = container.getAttribute("data-tags");
    if (!rawData) return;

    var tags = JSON.parse(rawData);
    if (!tags.length) return;

    drawWordCloud(canvas, tags);

    var resizeTimer;
    var resizeHandler = function() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function() { drawWordCloud(canvas, tags); }, 200);
    };
    window.addEventListener("resize", resizeHandler);

    var observer = new MutationObserver(function() {
      drawWordCloud(canvas, tags);
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ["class"] });

    document.addEventListener("swup:willReplaceContent", function() {
      window.removeEventListener("resize", resizeHandler);
      observer.disconnect();
    }, { once: true });
  }

  initTagWordcloud();
  document.addEventListener("astro:page-load", initTagWordcloud);
  document.addEventListener("swup:contentReplaced", initTagWordcloud);
})();
</script>
