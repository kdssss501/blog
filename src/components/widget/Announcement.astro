---
import Icon from "@components/common/Icon.astro";
import WidgetLayout from "@/components/common/WidgetLayout.astro";
import { announcementConfig } from "@/config/announcementConfig";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";

const config = announcementConfig;
const items = [...config.items].sort((a, b) => b.sort - a.sort);

interface Props {
	class?: string;
	style?: string;
}
const className = Astro.props.class;
const style = Astro.props.style;
---

<!-- 组件显示现在由sidebarLayoutConfig统一控制，无需检查config.enable -->
<WidgetLayout
  name={config.title || i18n(I18nKey.announcement)}
  id="announcement"
  class={className}
  style={style}
>
  <div class="announcement-list">
    {
      items.map((item) => (
        <div class="announcement-item">
          <div class="announcement-item__header">
            <span class="announcement-item__tag">{item.tag}</span>
            <span class="announcement-item__title">{item.title}</span>
          </div>
          <time class="announcement-item__time">{item.time}</time>
          <p class="announcement-item__content">{item.content}</p>
          {item.link && (
            <a
              href={item.link}
              class="announcement-item__link btn-regular rounded-lg px-3 py-1.5 text-sm font-medium active:scale-95 transition-transform"
            >
              查看详情
            </a>
          )}
        </div>
      ))
    }
  </div>

  {
    config.closable && (
      <div class="flex justify-end mt-3">
        <button
          class="btn-regular rounded-lg h-8 w-8 text-sm hover:bg-red-100 dark:hover:bg-red-900/30 transition-colors"
          onclick="this.closest('widget-layout').style.display='none'"
          aria-label={i18n(I18nKey.announcementClose)}
        >
          <Icon name="fa7-solid:xmark" class="text-sm" />
        </button>
      </div>
    )
  }
</WidgetLayout>
