---
import { getTagUrl } from "@utils/url-utils";
import type { Tag } from "@/utils/content-utils";

interface Props {
	tags: Tag[];
}

const { tags } = Astro.props;

// 按文章数降序
const sorted = [...tags].sort((a, b) => b.count - a.count);
const maxCount = sorted[0]?.count ?? 1;
---

<div class="tag-card-wall">
  {sorted.map((tag) => {
    const level = tag.count >= maxCount * 0.6 ? "lg"
      : tag.count >= maxCount * 0.3 ? "md"
      : "sm";
    return (
      <a href={getTagUrl(tag.name)} class={`tag-card tag-card--${level}`}>
        <span class="tag-card__name">#{tag.name}</span>
        <span class="tag-card__count">{tag.count} 篇</span>
      </a>
    );
  })}
</div>
