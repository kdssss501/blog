---
import { commentConfig } from "@/config";

interface Props {
	path: string;
}

const config = {
	...commentConfig.waline,
	el: "#waline",
	path: Astro.props.path,
	dark: "html.dark",
	wordLimit: ["2", "300"],
	...(commentConfig.waline?.visitorCount ? { pageview: true } : {}),
};
---
<!-- Waline -->
<div class="relative w-full">
  <div id="waline"></div>
  <link rel="stylesheet" href="https://unpkg.com/@waline/client@3/dist/waline.css" />
  <script type="module" is:inline define:vars={{ config }}>
    const cdnUrls = [
      'https://unpkg.com/@waline/client@3/dist/waline.js',
      'https://cdn.jsdelivr.net/npm/@waline/client@3/dist/waline.js'
    ];
    
    async function loadWaline(urls) {
      for (const url of urls) {
        try {
          const { init } = await import(url);
          init(config);
          return;
        } catch (error) {
          console.warn(`Failed to load Waline from ${url}:`, error);
        }
      }
      console.error('Failed to load Waline from all CDN sources');
    }
    
    loadWaline(cdnUrls);
  </script>
</div>