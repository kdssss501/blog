---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import { getCategoryList } from "@utils/content-utils";
import { getIconSvg } from "@/constants/icons";
import { isHomePage } from "@/utils/layout-utils";
import { url } from "@/utils/url-utils";

interface Props {
	title?: string;
	postSlug?: string;
	postCategory?: string;
}

const { title, postSlug, postCategory } = Astro.props as Props;

// 统一去掉尾部斜杠进行比较
const pathname = Astro.url.pathname.replace(/\/+$/, "");
const searchParams = Astro.url.searchParams;

const homeUrl = url("/");
const isHome = isHomePage(pathname);
const isPostPage = !!postSlug;

// 归档页匹配：/archive 或 /archive?category=xxx
const archivePath = url("/archive/").replace(/\/+$/, "");
const isArchivePage = pathname === archivePath;

const currentCategory = searchParams.get("category") || "";
const categories = isArchivePage || isPostPage ? await getCategoryList() : [];

// 路径 → 页面配置映射（集中管理，便于扩展）
const pageMap: Record<string, { label: string; icon: string }> = {
	"/about": {
		label: i18n(I18nKey.about),
		icon: "material-symbols:info-outline-rounded",
	},
	"/friends": {
		label: i18n(I18nKey.friends),
		icon: "material-symbols:group-rounded",
	},
	"/guestbook": {
		label: i18n(I18nKey.guestbook),
		icon: "material-symbols:mode-comment-rounded",
	},
	"/sponsor": {
		label: i18n(I18nKey.sponsor),
		icon: "material-symbols:volunteer-activism-rounded",
	},
	"/search": {
		label: i18n(I18nKey.search),
		icon: "material-symbols:search-rounded",
	},
	"/calendar": {
		label: i18n(I18nKey.calendar),
		icon: "material-symbols:calendar-month-rounded",
	},
};

interface BreadcrumbItem {
	label: string;
	href: string;
	icon: string;
	isCurrent: boolean;
	isDropdown?: boolean;
}

interface CategoryDropdownOption {
	label: string;
	value: string;
	href: string;
}

const archiveUrl = url("/archive/");

function getCategoryValue(categoryName: string): string {
	return categoryName === i18n(I18nKey.uncategorized)
		? "__uncategorized__"
		: categoryName;
}

function getCategoryHref(value: string): string {
	if (value === "") return archiveUrl;
	if (value === "__uncategorized__") return `${archiveUrl}?uncategorized=true`;
	return `${archiveUrl}?category=${encodeURIComponent(value)}`;
}

const dropdownOptions: CategoryDropdownOption[] = [
	{
		label: `${i18n(I18nKey.archive)} · ${i18n(I18nKey.all)}`,
		value: "",
		href: archiveUrl,
	},
	...categories.map((c) => {
		const value = getCategoryValue(c.name);
		return {
			label: `${c.name.trim()} (${c.count})`,
			value,
			href: getCategoryHref(value),
		};
	}),
];

const currentDropdownValue = isArchivePage
	? searchParams.has("uncategorized")
		? "__uncategorized__"
		: currentCategory
	: postCategory
		? getCategoryValue(postCategory)
		: "__uncategorized__";
const currentDropdownOption =
	dropdownOptions.find((option) => option.value === currentDropdownValue) ??
	dropdownOptions[0];

let items: BreadcrumbItem[] = [];

if (!isHome) {
	const homeItem: BreadcrumbItem = {
		label: i18n(I18nKey.home),
		href: homeUrl,
		icon: "material-symbols:home-rounded",
		isCurrent: false,
	};

	if (isPostPage) {
		// 文章页：首页 / 分类下拉 / 文章标题
		const categoryLabel = postCategory || i18n(I18nKey.uncategorized);
		items = [
			homeItem,
			{
				label: categoryLabel,
				href: "",
				icon: "material-symbols:folder-open-rounded",
				isCurrent: false,
				isDropdown: true,
			},
			{
				label: title || "",
				href: "",
				icon: "material-symbols:article-rounded",
				isCurrent: true,
			},
		];
	} else if (isArchivePage) {
		// 归档页：首页 / 分类下拉
		items = [
			homeItem,
			{
				label: currentCategory || i18n(I18nKey.archive),
				href: "",
				icon: currentCategory
					? "material-symbols:folder-open-rounded"
					: "material-symbols:folder-rounded",
				isCurrent: true,
				isDropdown: true,
			},
		];
	} else if (pathname === "/gallery" || pathname.startsWith("/gallery/")) {
		// 相册页：首页 / 相册 / [子相册]
		const albumMatch = pathname.match(/^\/gallery\/(.+)$/);
		if (albumMatch) {
			items = [
				homeItem,
				{
					label: i18n(I18nKey.gallery),
					href: "/gallery/",
					icon: "material-symbols:photo-library-outline-rounded",
					isCurrent: false,
				},
				{
					label: title || decodeURIComponent(albumMatch[1]),
					href: "",
					icon: "material-symbols:photo-frame-rounded",
					isCurrent: true,
				},
			];
		} else {
			items = [
				homeItem,
				{
					label: i18n(I18nKey.gallery),
					href: "/gallery/",
					icon: "material-symbols:photo-library-outline-rounded",
					isCurrent: true,
				},
			];
		}
	} else if (pageMap[pathname]) {
		// 普通页面：首页 / 页面名
		const page = pageMap[pathname];
		items = [
			homeItem,
			{
				label: title || page.label,
				href: `${pathname}/`,
				icon: page.icon,
				isCurrent: true,
			},
		];
	} else {
		// 兜底：首页 / 页面标题
		items = [
			homeItem,
			{
				label: title || "",
				href: "",
				icon: "material-symbols:description-rounded",
				isCurrent: true,
			},
		];
	}
}
---

{items.length > 0 && (
<nav class="cb" id="breadcrumb-nav" aria-label="Breadcrumb">
	<ol class="cb__list">
		{items.map((item, idx) => (
			<li class="cb__item">
				{idx > 0 && <span class="cb__sep" aria-hidden="true">›</span>}
				{item.isDropdown ? (
					<span
						class="cb__dropdown"
						data-breadcrumb-dropdown
						data-current-value={currentDropdownValue}
					>
						<button
							type="button"
							class="cb__dropdown-trigger"
							aria-haspopup="menu"
							aria-expanded="false"
							data-breadcrumb-dropdown-trigger
						>
							<span class="cb__dropdown-label" data-breadcrumb-dropdown-label>
								{currentDropdownOption.label}
							</span>
							<span
								class="cb__dropdown-arrow"
								aria-hidden="true"
								set:html={getIconSvg("material-symbols:keyboard-arrow-down-rounded")}
							/>
						</button>
						<span
							class="cb__dropdown-menu"
							role="menu"
							data-breadcrumb-dropdown-menu
						>
							{dropdownOptions.map((option) => (
								<a
									href={option.href}
									class:list={[
										"cb__dropdown-item",
										option.value === currentDropdownValue && "is-active",
									]}
									role="menuitem"
									data-breadcrumb-dropdown-item
									data-value={option.value}
								>
									<span>{option.label}</span>
								</a>
							))}
						</span>
					</span>
				) : item.isCurrent ? (
					<span class="cb__current">
						<span class="cb__icon" set:html={getIconSvg(item.icon)} />
						<span>{item.label}</span>
					</span>
				) : (
					<a href={item.href} class="cb__link">
						<span class="cb__icon" set:html={getIconSvg(item.icon)} />
						<span>{item.label}</span>
					</a>
				)}
			</li>
		))}
	</ol>
</nav>
)}

<script is:inline>
(function() {
	if (window.__breadcrumbInitialized) return;
	window.__breadcrumbInitialized = true;

	function getCategoryNavigateUrl(value) {
		var archiveUrl = "/archive/";
		if (value === "") return archiveUrl;
		if (value === "__uncategorized__") return archiveUrl + "?uncategorized=true";
		return archiveUrl + "?category=" + encodeURIComponent(value);
	}

	function navigate(targetUrl) {
		if (typeof window !== "undefined" && window.navigateToPage) {
			window.navigateToPage(targetUrl);
		} else {
			window.location.assign(targetUrl);
		}
	}

	function syncDropdown() {
		var params = new URLSearchParams(window.location.search);
		var targetValue = "";
		if (params.has("uncategorized")) {
			targetValue = "__uncategorized__";
		} else if (params.has("category")) {
			targetValue = params.get("category");
		} else if (window.location.pathname.indexOf("/posts/") !== -1) {
			var main = document.querySelector("main[data-current-post-category]");
			targetValue = (main && main.dataset.currentPostCategory) || "__uncategorized__";
		}
		var dropdowns = document.querySelectorAll("[data-breadcrumb-dropdown]");
		for (var i = 0; i < dropdowns.length; i++) {
			var dropdown = dropdowns[i];
			dropdown.setAttribute("data-current-value", targetValue);
			var items = dropdown.querySelectorAll("[data-breadcrumb-dropdown-item]");
			var activeLabel = "";
			for (var j = 0; j < items.length; j++) {
				var item = items[j];
				var active = item.getAttribute("data-value") === targetValue;
				item.classList.toggle("is-active", active);
				if (active) activeLabel = item.textContent || "";
			}
			var label = dropdown.querySelector("[data-breadcrumb-dropdown-label]");
			if (label && activeLabel) label.textContent = activeLabel.trim();
		}
	}

	function closeDropdown(dropdown) {
		var trigger = dropdown.querySelector("[data-breadcrumb-dropdown-trigger]");
		if (trigger) trigger.setAttribute("aria-expanded", "false");
		dropdown.classList.remove("is-open");
	}

	function openDropdown(dropdown) {
		var trigger = dropdown.querySelector("[data-breadcrumb-dropdown-trigger]");
		if (trigger) trigger.setAttribute("aria-expanded", "true");
		dropdown.classList.add("is-open");
	}

	function closeAllDropdowns() {
		var dropdowns = document.querySelectorAll("[data-breadcrumb-dropdown]");
		for (var i = 0; i < dropdowns.length; i++) closeDropdown(dropdowns[i]);
	}

	function focusItem(dropdown, direction) {
		var items = Array.prototype.slice.call(dropdown.querySelectorAll("[data-breadcrumb-dropdown-item]"));
		if (!items.length) return;
		var active = document.activeElement;
		var currentIndex = items.indexOf(active);
		var nextIndex = currentIndex < 0
			? 0
			: (currentIndex + direction + items.length) % items.length;
		items[nextIndex].focus();
	}

	// 事件委托：只注册一次，处理所有 breadcrumb dropdown interactions
	document.addEventListener("click", function(e) {
		var target = e.target;
		if (!target) return;
		var trigger = target.closest && target.closest("[data-breadcrumb-dropdown-trigger]");
		var item = target.closest && target.closest("[data-breadcrumb-dropdown-item]");
		if (trigger) {
			e.preventDefault();
			var dropdown = trigger.closest("[data-breadcrumb-dropdown]");
			if (!dropdown) return;
			var isOpen = dropdown.classList.contains("is-open");
			closeAllDropdowns();
			if (!isOpen) openDropdown(dropdown);
			return;
		}
		if (item) {
			e.preventDefault();
			var targetUrl = item.getAttribute("href") || getCategoryNavigateUrl(item.getAttribute("data-value") || "");
			closeAllDropdowns();
			navigate(targetUrl);
			return;
		}
		if (!target.closest || !target.closest("[data-breadcrumb-dropdown]")) closeAllDropdowns();
	});

	document.addEventListener("keydown", function(e) {
		var target = e.target;
		if (!target) return;
		var trigger = target.closest && target.closest("[data-breadcrumb-dropdown-trigger]");
		var item = target.closest && target.closest("[data-breadcrumb-dropdown-item]");
		var dropdown = (trigger || item) && (trigger || item).closest("[data-breadcrumb-dropdown]");
		if (!dropdown) return;

		if (trigger && (e.key === "Enter" || e.key === " ")) {
			e.preventDefault();
			dropdown.classList.contains("is-open") ? closeDropdown(dropdown) : openDropdown(dropdown);
		} else if (trigger && e.key === "ArrowDown") {
			e.preventDefault();
			openDropdown(dropdown);
			focusItem(dropdown, 1);
		} else if (item && e.key === "ArrowDown") {
			e.preventDefault();
			focusItem(dropdown, 1);
		} else if (item && e.key === "ArrowUp") {
			e.preventDefault();
			focusItem(dropdown, -1);
		} else if (item && (e.key === "Enter" || e.key === " ")) {
			e.preventDefault();
			navigate(item.getAttribute("href") || getCategoryNavigateUrl(item.getAttribute("data-value") || ""));
		} else if (e.key === "Escape") {
			closeDropdown(dropdown);
			var dropdownTrigger = dropdown.querySelector("[data-breadcrumb-dropdown-trigger]");
			if (dropdownTrigger) dropdownTrigger.focus();
		}
	});

	// 初始化 + swup 导航后同步
	syncDropdown();
	document.addEventListener("astro:page-load", function() {
		closeAllDropdowns();
		setTimeout(syncDropdown, 50);
	});
})();
</script>
