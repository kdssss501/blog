---
---

<dialog id="guestbook-detail-modal" class="gb-detail-modal">
	<div class="gb-detail-overlay" data-close-detail></div>
	<div class="gb-detail-panel">
		<!-- 角标装饰 -->
		<div class="corner-mark top-left"></div>
		<div class="corner-mark top-right"></div>
		<div class="corner-mark bottom-left"></div>
		<div class="corner-mark bottom-right"></div>

		<!-- 头部 -->
		<div class="detail-header">
			<div class="header-bg"></div>
			<div class="header-content">
				<div class="author-info">
					<div class="author-avatar"></div>
					<span class="author-name" id="detail-author"></span>
				</div>
				<span class="message-time" id="detail-time"></span>
			</div>
			<button class="btn-close" data-close-detail aria-label="关闭">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
					<line x1="18" y1="6" x2="6" y2="18"/>
					<line x1="6" y1="6" x2="18" y2="18"/>
				</svg>
			</button>
		</div>

		<!-- 留言信息 -->
		<div class="detail-body">
			<div class="body-line"></div>
			<div class="body-content">
				<h3 class="message-title" id="detail-title"></h3>
				<div class="title-underline"></div>
				<p class="detail-text" id="detail-content"></p>
			</div>
		</div>

		<!-- 投票统计 -->
		<div class="detail-stats">
			<span class="stat-text agree">赞同 <span id="detail-agree">0</span></span>
			<span class="stat-divider">|</span>
			<span class="stat-text neutral">中立 <span id="detail-neutral">0</span></span>
			<span class="stat-divider">|</span>
			<span class="stat-text disagree">反对 <span id="detail-disagree">0</span></span>
		</div>

		<!-- 底部 -->
		<div class="card-footer"></div>
	</div>
</dialog>

<script>
	function initGuestbookDetailModal() {
		const modal = document.getElementById('guestbook-detail-modal') as HTMLDialogElement | null;
		if (!modal) return;
		// 防止 swup 重复执行脚本或 astro:page-load 多次触发导致重复初始化
		if ((modal as any).__gb_initialized) return;
		(modal as any).__gb_initialized = true;

		function closeModal() {
			modal!.close();
			document.body.style.overflow = '';
		}

		// 移除旧处理器防止累积
		if ((window as any).__gb_open_detail_handler) {
			window.removeEventListener('guestbook:open-detail', (window as any).__gb_open_detail_handler);
		}
		const openDetailHandler = (e: Event) => {
			if (!modal.isConnected) return;
			const card = (e as CustomEvent).detail;
			if (!card) return;

			const authorEl = document.getElementById('detail-author');
			const timeEl = document.getElementById('detail-time');
			const titleEl = document.getElementById('detail-title');
			const contentEl = document.getElementById('detail-content');
			const agreeEl = document.getElementById('detail-agree');
			const neutralEl = document.getElementById('detail-neutral');
			const disagreeEl = document.getElementById('detail-disagree');

			if (authorEl) authorEl.textContent = card.author;
			if (timeEl) timeEl.textContent = card.time;
			if (titleEl) titleEl.textContent = '留言 #' + card.id.split('_')[1];
			if (contentEl) contentEl.textContent = card.content;
			if (agreeEl) agreeEl.textContent = card.votes.agree;
			if (neutralEl) neutralEl.textContent = card.votes.neutral;
			if (disagreeEl) disagreeEl.textContent = card.votes.disagree;

			modal.showModal();
			document.body.style.overflow = 'hidden';
		};
		(window as any).__gb_open_detail_handler = openDetailHandler;
		window.addEventListener('guestbook:open-detail', openDetailHandler);

		modal.querySelectorAll('[data-close-detail]').forEach(el => {
			el.addEventListener('click', closeModal);
		});

		modal.addEventListener('click', (e) => {
			if (e.target === modal) closeModal();
		});

		modal.addEventListener('close', () => {
			document.body.style.overflow = '';
		});

		modal.addEventListener('cancel', (e) => {
			e.preventDefault();
			closeModal();
		});
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initGuestbookDetailModal);
	} else {
		initGuestbookDetailModal();
	}
	document.addEventListener('astro:page-load', initGuestbookDetailModal);
</script>

<!-- 样式已迁移至 src/styles/components/guestbook-modals.css -->
