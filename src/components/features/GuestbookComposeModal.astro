---
---

<dialog id="guestbook-compose-modal" class="gb-compose-modal">
	<div class="gb-compose-overlay" data-close-compose></div>
	<div class="gb-compose-panel">
		<!-- 角标装饰 -->
		<div class="corner-mark top-left"></div>
		<div class="corner-mark top-right"></div>
		<div class="corner-mark bottom-left"></div>
		<div class="corner-mark bottom-right"></div>

		<!-- 头部 -->
		<div class="compose-header">
			<div class="header-bg"></div>
			<div class="header-content">
				<div class="author-info">
					<div class="author-avatar"></div>
					<span class="header-title">发表留言</span>
				</div>
				<button class="btn-close" data-close-compose aria-label="关闭">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
						<line x1="18" y1="6" x2="6" y2="18"/>
						<line x1="6" y1="6" x2="18" y2="18"/>
					</svg>
				</button>
			</div>
		</div>

		<!-- 表单主体 -->
		<div class="compose-body">
			<div class="body-line"></div>
			<div class="body-content">
				<div class="form-fields">
					<div class="field-group">
					<label class="field-label" for="gb-author">
						昵称
					</label>
						<input
							id="gb-author"
							type="text"
							class="field-input"
							placeholder="输入你的昵称..."
							maxlength={30}
						/>
						<div class="field-hint">2-30个字符</div>
					</div>

					<div class="field-group">
					<label class="field-label" for="gb-content">
						留言内容
					</label>
						<textarea
							id="gb-content"
							class="field-textarea"
							placeholder="写下你想说的话..."
							rows="5"
							maxlength={500}
						></textarea>
						<div class="char-count" id="gb-char-count">0/500</div>
						<div class="field-hint">5-500个字符，不支持HTML和脚本。请文明发言，友善交流，勿发布违规内容。</div>
					</div>
				</div>

				<div id="gb-error-message" class="error-message" style="display: none;">
					<span class="error-icon">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="12" cy="12" r="10"/>
							<line x1="12" y1="8" x2="12" y2="12"/>
							<line x1="12" y1="16" x2="12.01" y2="16"/>
						</svg>
					</span>
					<span class="error-text"></span>
					<button class="error-close" data-close-error>
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<line x1="18" y1="6" x2="6" y2="18"/>
							<line x1="6" y1="6" x2="18" y2="18"/>
						</svg>
					</button>
				</div>
			</div>
		</div>

		<!-- 底部操作 -->
		<div class="compose-footer">
			<button class="btn-submit" id="gb-submit" disabled>
				发送留言 >>
			</button>
		</div>
	</div>
</dialog>

<script>
	function initGuestbookComposeModal() {
		const modal = document.getElementById('guestbook-compose-modal') as HTMLDialogElement | null;
		if (!modal) return;
		// 防止 swup 重复执行脚本或 astro:page-load 多次触发导致重复初始化
		if ((modal as any).__gb_initialized) return;
		(modal as any).__gb_initialized = true;

		const authorInput = document.getElementById('gb-author') as HTMLInputElement | null;
		const contentInput = document.getElementById('gb-content') as HTMLTextAreaElement | null;
		const charCount = document.getElementById('gb-char-count');
		const submitBtn = document.getElementById('gb-submit') as HTMLButtonElement | null;

		if (!authorInput || !contentInput || !submitBtn) return;

		let isSubmitting = false;

		function updateSubmitState() {
			submitBtn!.disabled = !authorInput!.value.trim()
				|| !contentInput!.value.trim()
				|| isSubmitting;
		}

		// 字符计数
		contentInput.addEventListener('input', () => {
			if (charCount) charCount.textContent = contentInput.value.length + '/500';
			updateSubmitState();
		});
		authorInput.addEventListener('input', updateSubmitState);

		// 监听打开事件 — 移除旧处理器防止累积
		if ((window as any).__gb_open_compose_handler) {
			window.removeEventListener('guestbook:open-compose', (window as any).__gb_open_compose_handler);
		}
		const openComposeHandler = () => {
			if (!modal.isConnected) return;
			modal.showModal();
			document.body.style.overflow = 'hidden';
			authorInput.value = '';
			contentInput.value = '';
			if (charCount) charCount.textContent = '0/500';
			updateSubmitState();
			hideErrorMessage();
			setTimeout(() => authorInput.focus(), 100);
		};
		(window as any).__gb_open_compose_handler = openComposeHandler;
		window.addEventListener('guestbook:open-compose', openComposeHandler);

		// 关闭
		function closeModal() {
			modal!.close();
			document.body.style.overflow = '';
		}

		modal.querySelectorAll('[data-close-compose]').forEach(el => {
			el.addEventListener('click', closeModal);
		});

		modal.addEventListener('click', (e) => {
			if (e.target === modal) closeModal();
		});

		modal.addEventListener('close', () => {
			document.body.style.overflow = '';
		});

		modal.addEventListener('cancel', (e) => {
			e.preventDefault();
			closeModal();
		});

		const errorMessageEl = document.getElementById('gb-error-message');

		let errorAutoHideTimeout: ReturnType<typeof setTimeout> | null = null;

		function showErrorMessage(message: string) {
			if (!errorMessageEl) return;
			// 清除之前的自动隐藏定时器
			if (errorAutoHideTimeout) {
				clearTimeout(errorAutoHideTimeout);
				errorAutoHideTimeout = null;
			}
			const errorTextEl = errorMessageEl.querySelector('.error-text');
			if (errorTextEl) errorTextEl.textContent = message;
			errorMessageEl.style.display = 'flex';
			// 使用 requestAnimationFrame 确保 display:flex 生效后再添加 show 类
			requestAnimationFrame(() => {
				errorMessageEl!.classList.add('show');
			});
		}

		function hideErrorMessage() {
			if (!errorMessageEl) return;
			// 清除自动隐藏定时器
			if (errorAutoHideTimeout) {
				clearTimeout(errorAutoHideTimeout);
				errorAutoHideTimeout = null;
			}
			errorMessageEl.classList.remove('show');
			setTimeout(() => {
				if (!errorMessageEl!.classList.contains('show')) {
					errorMessageEl!.style.display = 'none';
				}
			}, 300);
		}

		if (errorMessageEl) {
			errorMessageEl.addEventListener('click', (e) => {
				if (e.target instanceof Element && e.target.closest('[data-close-error]')) {
					hideErrorMessage();
				}
			});
		}

		function getErrorMessage(status: number, errorText: string) {
			// 优先使用后端返回的具体错误信息
			if (errorText && errorText !== `Failed to post message: ${status}`) {
				// 如果后端返回了中文错误信息，直接使用
				if (/[\u4e00-\u9fa5]/.test(errorText)) return errorText;
				// 英文错误信息映射为中文
				const lower = errorText.toLowerCase();
				if (lower.includes('prohibited') || lower.includes('unsafe') || lower.includes('xss')) {
					return '内容包含不安全的内容，请检查是否包含脚本或特殊标签';
				}
				if (lower.includes('author')) return '昵称长度必须在2-30个字符之间';
				if (lower.includes('content')) {
					if (lower.includes('short')) return '内容太短，至少需要5个字符';
					if (lower.includes('long')) return '内容太长，最多500个字符';
					return '内容长度必须在5-500个字符之间';
				}
				if (lower.includes('rate limit') || lower.includes('too many')) {
					return '发送太频繁了，请稍后再试';
				}
			}
			// 根据状态码返回默认错误信息
			switch (status) {
				case 400: return '输入内容无效，请检查后重试';
				case 429: return '发送太频繁了，请稍后再试';
				case 500: return '服务器内部错误，请稍后重试';
				case 503: return '服务暂时不可用，请稍后重试';
				case 0: return '网络连接失败，请检查网络后重试';
				default: return `提交失败 (${status})，请稍后重试`;
			}
		}

		// 提交
		submitBtn.addEventListener('click', async () => {
			const author = (authorInput as HTMLInputElement).value.trim();
			const content = (contentInput as HTMLTextAreaElement).value.trim();
			if (!author || !content || isSubmitting) return;

			hideErrorMessage();
			isSubmitting = true;
			submitBtn.textContent = '发送中...';
			submitBtn.disabled = true;

			try {
				const { postGuestbookMessage } = await import('@/utils/guestbook-api');
				const message = await postGuestbookMessage(author, content);
				window.dispatchEvent(new CustomEvent('guestbooknew', { detail: message }));
				closeModal();
			} catch (err: any) {
				console.error('Failed to post message:', err);
				const status = err.status || 0;
				const errorText = err.message || '';
				const errorMsg = getErrorMessage(status, errorText);
				showErrorMessage('❌ ' + errorMsg);
			} finally {
				isSubmitting = false;
				submitBtn.textContent = '发送留言 >>';
				updateSubmitState();
			}
		});
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initGuestbookComposeModal);
	} else {
		initGuestbookComposeModal();
	}
	document.addEventListener('astro:page-load', initGuestbookComposeModal);
</script>

<!-- 样式已迁移至 src/styles/components/guestbook-modals.css -->
