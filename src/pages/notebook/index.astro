---
import PageTitle from "@/components/common/PageTitle.astro";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

const title = "笔记本";
const description = "记录生活与学习的点滴，按笔记本分类整理。";
---

<MainGridLayout title={title} description={description} showSidebar={true}>
	<div class="notebook-page">
		<section class="notebook-shell card-base">
			<div class="notebook-overview">
				<div class="notebook-overview__intro">
					<PageTitle title={title} eyebrow="Notebook" variant="stacked" />
					{description && <p class="notebook-overview__desc">{description}</p>}
					<p class="notebook-overview__lead">
						把不同主题的观感记录集中收拢到同一块区域里，延续动态页的三栏结构，让内容浏览和站点工具区保持统一节奏。
					</p>
				</div>

				<div class="notebook-overview__panel">
					<span class="notebook-overview__eyebrow">Notebook Overview</span>
					<h2 class="notebook-overview__title">在同一页里看清主题、数量和最近整理节奏</h2>
					<div class="notebook-overview__stats">
						<div class="notebook-overview__stat">
							<span class="notebook-overview__stat-label">主题数</span>
							<strong class="notebook-overview__stat-value" id="notebook-total-groups">0</strong>
						</div>
						<div class="notebook-overview__stat">
							<span class="notebook-overview__stat-label">笔记数</span>
							<strong class="notebook-overview__stat-value" id="notebook-total-entries">0</strong>
						</div>
						<div class="notebook-overview__stat">
							<span class="notebook-overview__stat-label">最近更新</span>
							<strong class="notebook-overview__stat-value" id="notebook-last-updated">整理中</strong>
						</div>
					</div>
					<p class="notebook-overview__note">
						当前优先展示 <span id="notebook-featured-name">最近更新主题</span>，概览卡片会直接进入对应笔记分组。
					</p>
				</div>
			</div>

			<div id="notebook-list-container">
				<div class="notebook-loading" id="notebook-loading">
					<span class="notebook-loading-dot"></span>
					<span>正在加载笔记本...</span>
				</div>

				<div class="notebook-empty hidden" id="notebook-empty">
					<p>还没有任何笔记本，先创建一个吧。</p>
				</div>

				<div class="notebook-grid hidden" id="notebook-masonry"></div>
			</div>
		</section>
	</div>

	<script>
import { GALLERY_IMAGES, hashString, getCoverImage } from "@/utils/notebook-covers";
import { getNotebookGroupMeta } from "@/utils/notebook-content";
window.notebookCovers = { GALLERY_IMAGES, hashString, getCoverImage };
window.notebookPresentation = { getNotebookGroupMeta };
window.escapeText = function(str) {
	const div = document.createElement("div");
	div.textContent = str;
	return div.innerHTML;
};
window.formatDate = function(timestamp) {
	const d = new Date(timestamp);
	const y = d.getFullYear();
	const m = String(d.getMonth() + 1).padStart(2, "0");
	const day = String(d.getDate()).padStart(2, "0");
	return y + "-" + m + "-" + day;
};
</script>

<script is:inline>
var notebookCovers = window.notebookCovers || {
	GALLERY_IMAGES: [
		"1.webp", "2.webp", "3.webp", "4.webp", "5.webp", "6.webp", "7.webp",
		"16.webp", "20.webp", "21.webp", "22.webp", "24.webp", "25.webp",
		"26.webp", "27.webp", "28.webp", "41.webp", "42.webp", "43.webp",
		"44.webp", "50.webp", "80.webp", "100.webp", "101.webp", "102.webp",
		"103.webp", "104.webp", "105.webp", "107.webp", "200.webp", "201.webp",
		"202.webp", "203.webp", "204.webp", "205.webp"
	],
	hashString: function(str) {
		let hash = 0;
		for (let i = 0; i < str.length; i++) {
			hash = ((hash << 5) - hash + str.charCodeAt(i)) | 0;
		}
		return Math.abs(hash);
	},
	getCoverImage: function(cover, name) {
		if (cover && (cover.indexOf("data:") === 0 || cover.indexOf("http") === 0)) {
			return cover;
		}
		let imgIndex = 0;
		if (cover && cover.indexOf("default-") === 0) {
			const num = parseInt(cover.replace("default-", ""), 10);
			if (!isNaN(num) && num >= 1 && num <= this.GALLERY_IMAGES.length) {
				imgIndex = num - 1;
			}
		} else {
			imgIndex = this.hashString(name || "n") % this.GALLERY_IMAGES.length;
		}
		return "/gallery/gpt-img2-2026/" + this.GALLERY_IMAGES[imgIndex];
	}
};
var notebookPresentation = window.notebookPresentation || {
	getNotebookGroupMeta: function(name) {
		return null;
	}
};

var notebookCache = {
		data: null,
		timestamp: 0,
		ttl: 300000,
		get: function(key) {
			try {
				var cached = sessionStorage.getItem("notebook_v2_" + key);
				if (!cached) return null;
				var parsed = JSON.parse(cached);
				if (Date.now() - parsed.timestamp < this.ttl) {
					return parsed.data;
				}
				sessionStorage.removeItem("notebook_v2_" + key);
				return null;
			} catch (e) {
				return null;
			}
		},
		set: function(key, data) {
			try {
				sessionStorage.setItem("notebook_v2_" + key, JSON.stringify({
					data: data,
					timestamp: Date.now()
				}));
			} catch (e) {}
		}
	};

        function safeEscapeText(value) {
                return window.escapeText ? window.escapeText(value) : String(value || "");
        }

	function renderCover(cover, name) {
	if (typeof notebookPresentation.getNotebookGroupMeta === "function") {
		var meta = notebookPresentation.getNotebookGroupMeta(name);
		if (meta && meta.coverImage) {
			return 'style="background-image: url(\'' + safeEscapeText(meta.coverImage) + '\');"';
		}
	}
	var url = typeof notebookCovers.getCoverImage === "function"
		? notebookCovers.getCoverImage(cover, name)
		: cover;
	return 'style="background-image: url(\'' + safeEscapeText(url) + '\');"';
}

	function groupByNotebook(entries) {
		var map = new Map();
		for (var i = 0; i < entries.length; i++) {
			var entry = entries[i];
			var list = map.get(entry.notebook) || [];
			list.push(entry);
			map.set(entry.notebook, list);
		}

		var groups = [];
		map.forEach(function(list, name) {
			var sorted = list.sort(function(a, b) { return b.updatedAt - a.updatedAt; });
			var latest = sorted[0];
			var description = latest ? latest.content.replace(/!\[[^\]]*\]\(([^)]+)\)/g, " ").replace(/\[[^\]]+\]\(([^)]+)\)/g, " ").replace(/[#*`>_-]/g, " ").replace(/\s+/g, " ").trim().slice(0, 72) : "";
			var presentation = window.notebookPresentation;
			var meta = presentation && typeof presentation.getNotebookGroupMeta === "function"
				? presentation.getNotebookGroupMeta(name)
				: null;
			groups.push({
				name: name,
				count: list.length,
				lastUpdated: latest ? latest.updatedAt : 0,
				cover: latest ? latest.cover : "",
				eyebrow: meta ? meta.eyebrow : "Notebook",
				description: meta ? meta.listDescription : (description || "暂无描述"),
				intro: meta ? meta.intro : "",
				tags: meta ? meta.tags : [],
			});
		});

		return groups.sort(function(a, b) { return b.lastUpdated - a.lastUpdated; });
	}

	function renderNotebookCards(groups) {
		var masonry = document.getElementById("notebook-masonry");
		if (!masonry) return;

		masonry.innerHTML = groups.map(function(group) {
			var url = "/notebook/view/?name=" + encodeURIComponent(group.name);
			var coverStyle = renderCover(group.cover, group.name);
			var tagsHtml = (group.tags || []).slice(0, 3).map(function(tag) {
				return '<span class="notebook-card__tag">' + safeEscapeText(tag) + '</span>';
			}).join("");
			return '<a href="' + url + '" class="notebook-card" ' + coverStyle + '>' +
				'<div class="notebook-card__badge">' + group.count + ' 篇</div>' +
				'<div class="notebook-card__overlay"></div>' +
				'<div class="notebook-card__body">' +
					'<span class="notebook-card__eyebrow">' + safeEscapeText(group.eyebrow || "Notebook") + '</span>' +
					'<h2 class="notebook-card__name">' + safeEscapeText(group.name) + '</h2>' +
					'<p class="notebook-card__desc">' + safeEscapeText(group.description) + '</p>' +
					(tagsHtml ? '<div class="notebook-card__tags">' + tagsHtml + '</div>' : '') +
				'</div>' +
			'</a>';
		}).join("");
	}

	function renderNotebookOverview(groups, entries) {
		var totalGroups = document.getElementById("notebook-total-groups");
		var totalEntries = document.getElementById("notebook-total-entries");
		var lastUpdated = document.getElementById("notebook-last-updated");
		var featuredName = document.getElementById("notebook-featured-name");
		var topGroup = groups && groups.length ? groups[0] : null;
		if (totalGroups) totalGroups.textContent = String(groups ? groups.length : 0);
		if (totalEntries) totalEntries.textContent = String(entries ? entries.length : 0);
		if (lastUpdated) {
			lastUpdated.textContent = topGroup && topGroup.lastUpdated
				? (window.formatDate ? window.formatDate(topGroup.lastUpdated) : String(topGroup.lastUpdated))
				: "整理中";
		}
		if (featuredName) {
			featuredName.textContent = topGroup && topGroup.name ? topGroup.name : "最近更新主题";
		}
	}

	function fetchWithTimeout(url, options, timeoutMs) {
		return new Promise(function(resolve, reject) {
			var controller = new AbortController();
			var timer = setTimeout(function() {
				controller.abort();
				reject(new Error("Request timeout"));
			}, timeoutMs || 10000);
			options = options || {};
			options.signal = controller.signal;
			fetch(url, options)
				.then(function(res) {
					clearTimeout(timer);
					resolve(res);
				})
				.catch(function(err) {
					clearTimeout(timer);
					reject(err);
				});
		});
	}

	function fetchWithExponentialRetry(url, options, timeoutMs, maxRetries) {
		return new Promise(function(resolve, reject) {
			var attempts = 0;
			var delay = 500;

			function attempt() {
				fetchWithTimeout(url, options, timeoutMs)
					.then(resolve)
					.catch(function(err) {
						attempts++;
						if (attempts <= maxRetries) {
							setTimeout(attempt, delay);
							delay = delay * 2;
						} else {
							reject(err);
						}
					});
			}

			attempt();
		});
	}

	var isLoading = false;

	function loadNotebooks(forceRefresh) {
		if (isLoading) return;
		isLoading = true;

		var loading = document.getElementById("notebook-loading");
		var empty = document.getElementById("notebook-empty");
		var masonry = document.getElementById("notebook-masonry");

		if (loading) loading.style.display = "flex";
		if (empty) empty.style.display = "none";
		if (masonry) masonry.style.display = "none";

		if (!forceRefresh) {
			var cachedData = notebookCache.get("list");
			if (cachedData) {
				processNotebookData(cachedData, loading, empty, masonry);
				isLoading = false;
				return;
			}
		}

		fetchWithExponentialRetry("/api/notebook/", { method: "GET" }, 10000, 3)
			.then(function(res) {
				if (!res.ok) throw new Error("Failed to load notebooks");
				return res.json();
			})
			.then(function(data) {
				notebookCache.set("list", data);
				processNotebookData(data, loading, empty, masonry);
			})
			.catch(function(err) {
				if (loading) loading.style.display = "none";
				if (empty) {
					empty.style.display = "flex";
					var p = empty.querySelector("p");
					if (p) p.textContent = "加载失败，点击重试";
					empty.style.cursor = "pointer";
					empty.onclick = function() { loadNotebooks(true); };
				}
				console.error("[notebook] load failed:", err);
			})
			.finally(function() {
				isLoading = false;
			});
	}

	function processNotebookData(data, loading, empty, masonry) {
		var entries = data.entries || [];

		if (loading) loading.style.display = "none";

		if (entries.length === 0) {
			if (empty) {
				empty.style.display = "flex";
				var p = empty.querySelector("p");
				if (p) p.textContent = "还没有任何笔记本，先创建一个吧。";
				empty.style.cursor = "default";
				empty.onclick = null;
			}
			return;
		}

		var groups = groupByNotebook(entries);
		renderNotebookOverview(groups, entries);
		renderNotebookCards(groups);
		if (masonry) masonry.style.display = "grid";
	}

	function handleVisibilityChange() {
		if (document.visibilityState === "visible") {
			var masonry = document.getElementById("notebook-masonry");
			if (!masonry || masonry.style.display !== "grid") {
				loadNotebooks(false);
			}
		}
	}

	loadNotebooks(false);
	if (window.__notebookListPageLoadHandler) {
		document.removeEventListener("astro:page-load", window.__notebookListPageLoadHandler);
	}
	if (window.__notebookListVisibilityHandler) {
		document.removeEventListener("visibilitychange", window.__notebookListVisibilityHandler);
	}
	window.__notebookListPageLoadHandler = function() { loadNotebooks(false); };
	window.__notebookListVisibilityHandler = handleVisibilityChange;
	document.addEventListener("astro:page-load", window.__notebookListPageLoadHandler);
	document.addEventListener("visibilitychange", handleVisibilityChange);
	</script>
</MainGridLayout>
