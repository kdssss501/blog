---
import PageTitle from "@/components/common/PageTitle.astro";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

const title = "笔记本";
const description = "记录生活与学习的点滴，按笔记本分类整理。";
---

<MainGridLayout title={title} description={description}>
	<div class="notebook-page flex w-full rounded-(--radius-large) relative min-h-32">
		<div class="card-base z-10 px-4 py-6 md:px-9 relative w-full">
			<!-- 页面标题 -->
			<div class="mb-6">
				<PageTitle title={title} eyebrow="Notebook" variant="stacked" />
				{description && (
					<p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed mt-3">
						{description}
					</p>
				)}
			</div>

			<!-- 笔记本列表容器 -->
			<div id="notebook-list-container">
				<!-- 加载状态 -->
				<div class="notebook-loading" id="notebook-loading">
					<span class="notebook-loading-dot"></span>
					<span>正在加载笔记本...</span>
				</div>

				<!-- 空状态 -->
				<div class="notebook-empty hidden" id="notebook-empty">
					<p>还没有任何笔记本，先创建一个吧。</p>
				</div>

				<!-- 笔记本卡片瀑布流 -->
				<div class="notebook-masonry hidden" id="notebook-masonry"></div>
			</div>
		</div>
	</div>

	<script>
	import { GALLERY_IMAGES, hashString, getCoverImage } from "@/utils/notebook-covers";
	import { getNotebookGroupMeta } from "@/utils/notebook-content";
	window.notebookCovers = { GALLERY_IMAGES, hashString, getCoverImage };
	window.notebookPresentation = { getNotebookGroupMeta };
	window.escapeText = function(str) {
		const div = document.createElement("div");
		div.textContent = str;
		return div.innerHTML;
	};
	window.formatDate = function(timestamp) {
		const d = new Date(timestamp);
		const y = d.getFullYear();
		const m = String(d.getMonth() + 1).padStart(2, "0");
		const day = String(d.getDate()).padStart(2, "0");
		return y + "-" + m + "-" + day;
	};
</script>

<script is:inline>
	var notebookCache = {
		data: null,
		timestamp: 0,
		ttl: 300000,
		get: function(key) {
			try {
				var cached = sessionStorage.getItem("notebook_" + key);
				if (!cached) return null;
				var parsed = JSON.parse(cached);
				if (Date.now() - parsed.timestamp < this.ttl) {
					return parsed.data;
				}
				sessionStorage.removeItem("notebook_" + key);
				return null;
			} catch (e) {
				return null;
			}
		},
		set: function(key, data) {
			try {
				sessionStorage.setItem("notebook_" + key, JSON.stringify({
					data: data,
					timestamp: Date.now()
				}));
			} catch (e) {}
		}
	};

        function safeEscapeText(value) {
                return window.escapeText ? window.escapeText(value) : String(value || "");
        }

	function renderCover(cover, name) {
		var presentation = window.notebookPresentation;
		if (presentation && typeof presentation.getNotebookGroupMeta === "function") {
			var meta = presentation.getNotebookGroupMeta(name);
			if (meta && meta.coverImage) {
				return 'style="background-image: url(\'' + safeEscapeText(meta.coverImage) + '\');"';
			}
		}
		var helpers = window.notebookCovers;
		var url = helpers ? helpers.getCoverImage(cover, name) : cover;
		return 'style="background-image: url(\'' + safeEscapeText(url) + '\');"';
	}

	function groupByNotebook(entries) {
		var map = new Map();
		for (var i = 0; i < entries.length; i++) {
			var entry = entries[i];
			var list = map.get(entry.notebook) || [];
			list.push(entry);
			map.set(entry.notebook, list);
		}

		var groups = [];
		map.forEach(function(list, name) {
			var sorted = list.sort(function(a, b) { return b.updatedAt - a.updatedAt; });
			var latest = sorted[0];
			var description = latest ? latest.content.replace(/!\[[^\]]*\]\(([^)]+)\)/g, " ").replace(/\[[^\]]+\]\(([^)]+)\)/g, " ").replace(/[#*`>_-]/g, " ").replace(/\s+/g, " ").trim().slice(0, 72) : "";
			var presentation = window.notebookPresentation;
			var meta = presentation && typeof presentation.getNotebookGroupMeta === "function"
				? presentation.getNotebookGroupMeta(name)
				: null;
			groups.push({
				name: name,
				count: list.length,
				lastUpdated: latest ? latest.updatedAt : 0,
				cover: latest ? latest.cover : "",
				eyebrow: meta ? meta.eyebrow : "Notebook",
				description: meta ? meta.listDescription : (description || "暂无描述"),
				intro: meta ? meta.intro : "",
				tags: meta ? meta.tags : [],
			});
		});

		return groups.sort(function(a, b) { return b.lastUpdated - a.lastUpdated; });
	}

	function renderNotebookCards(groups) {
		var masonry = document.getElementById("notebook-masonry");
		if (!masonry) return;

		masonry.innerHTML = groups.map(function(group) {
			var url = "/notebook/view/?name=" + encodeURIComponent(group.name);
			var coverStyle = renderCover(group.cover, group.name);
			var tagsHtml = (group.tags || []).slice(0, 3).map(function(tag) {
				return '<span class="notebook-card__tag">' + safeEscapeText(tag) + '</span>';
			}).join("");
			return '<a href="' + url + '" class="notebook-card" ' + coverStyle + '>' +
				'<div class="notebook-card__badge">' + group.count + ' 篇</div>' +
				'<div class="notebook-card__overlay"></div>' +
				'<div class="notebook-card__body">' +
					'<span class="notebook-card__eyebrow">' + safeEscapeText(group.eyebrow || "Notebook") + '</span>' +
					'<h2 class="notebook-card__name">' + safeEscapeText(group.name) + '</h2>' +
					'<p class="notebook-card__desc">' + safeEscapeText(group.description) + '</p>' +
					(tagsHtml ? '<div class="notebook-card__tags">' + tagsHtml + '</div>' : '') +
				'</div>' +
			'</a>';
		}).join("");
	}

	function fetchWithTimeout(url, options, timeoutMs) {
		return new Promise(function(resolve, reject) {
			var controller = new AbortController();
			var timer = setTimeout(function() {
				controller.abort();
				reject(new Error("Request timeout"));
			}, timeoutMs || 10000);
			options = options || {};
			options.signal = controller.signal;
			fetch(url, options)
				.then(function(res) {
					clearTimeout(timer);
					resolve(res);
				})
				.catch(function(err) {
					clearTimeout(timer);
					reject(err);
				});
		});
	}

	function fetchWithExponentialRetry(url, options, timeoutMs, maxRetries) {
		return new Promise(function(resolve, reject) {
			var attempts = 0;
			var delay = 500;

			function attempt() {
				fetchWithTimeout(url, options, timeoutMs)
					.then(resolve)
					.catch(function(err) {
						attempts++;
						if (attempts <= maxRetries) {
							setTimeout(attempt, delay);
							delay = delay * 2;
						} else {
							reject(err);
						}
					});
			}

			attempt();
		});
	}

	var isLoading = false;

	function loadNotebooks(forceRefresh) {
		if (isLoading) return;
		isLoading = true;

		var loading = document.getElementById("notebook-loading");
		var empty = document.getElementById("notebook-empty");
		var masonry = document.getElementById("notebook-masonry");

		if (loading) loading.style.display = "flex";
		if (empty) empty.style.display = "none";
		if (masonry) masonry.style.display = "none";

		if (!forceRefresh) {
			var cachedData = notebookCache.get("list");
			if (cachedData) {
				processNotebookData(cachedData, loading, empty, masonry);
				isLoading = false;
				return;
			}
		}

		fetchWithExponentialRetry("/api/notebook/", { method: "GET" }, 10000, 3)
			.then(function(res) {
				if (!res.ok) throw new Error("Failed to load notebooks");
				return res.json();
			})
			.then(function(data) {
				notebookCache.set("list", data);
				processNotebookData(data, loading, empty, masonry);
			})
			.catch(function(err) {
				if (loading) loading.style.display = "none";
				if (empty) {
					empty.style.display = "flex";
					var p = empty.querySelector("p");
					if (p) p.textContent = "加载失败，点击重试";
					empty.style.cursor = "pointer";
					empty.onclick = function() { loadNotebooks(true); };
				}
				console.error("[notebook] load failed:", err);
			})
			.finally(function() {
				isLoading = false;
			});
	}

	function processNotebookData(data, loading, empty, masonry) {
		var entries = data.entries || [];

		if (loading) loading.style.display = "none";

		if (entries.length === 0) {
			if (empty) {
				empty.style.display = "flex";
				var p = empty.querySelector("p");
				if (p) p.textContent = "还没有任何笔记本，先创建一个吧。";
				empty.style.cursor = "default";
				empty.onclick = null;
			}
			return;
		}

		var groups = groupByNotebook(entries);
		renderNotebookCards(groups);
		if (masonry) masonry.style.display = "block";
	}

	function handleVisibilityChange() {
		if (document.visibilityState === "visible") {
			var masonry = document.getElementById("notebook-masonry");
			if (!masonry || masonry.style.display !== "block") {
				loadNotebooks(false);
			}
		}
	}

	loadNotebooks(false);
	if (window.__notebookListPageLoadHandler) {
		document.removeEventListener("astro:page-load", window.__notebookListPageLoadHandler);
	}
	if (window.__notebookListVisibilityHandler) {
		document.removeEventListener("visibilitychange", window.__notebookListVisibilityHandler);
	}
	window.__notebookListPageLoadHandler = function() { loadNotebooks(false); };
	window.__notebookListVisibilityHandler = handleVisibilityChange;
	document.addEventListener("astro:page-load", window.__notebookListPageLoadHandler);
	document.addEventListener("visibilitychange", handleVisibilityChange);
	</script>
</MainGridLayout>
