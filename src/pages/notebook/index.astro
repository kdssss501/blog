---
import PageTitle from "@/components/common/PageTitle.astro";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

const title = "笔记本";
const description = "记录生活与学习的点滴，按笔记本分类整理。";
---

<MainGridLayout title={title} description={description}>
	<div class="flex w-full rounded-(--radius-large) relative min-h-32">
		<div class="card-base z-10 px-4 py-6 md:px-9 relative w-full">
			<!-- 页面标题 -->
			<div class="mb-6">
				<PageTitle title={title} eyebrow="Notebook" variant="stacked" />
				{description && (
					<p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed mt-3">
						{description}
					</p>
				)}
			</div>

			<!-- 笔记本列表容器 -->
			<div id="notebook-list-container">
				<!-- 加载状态 -->
				<div class="notebook-loading" id="notebook-loading">
					<span class="notebook-loading-dot"></span>
					<span>正在加载笔记本...</span>
				</div>

				<!-- 空状态 -->
				<div class="notebook-empty hidden" id="notebook-empty">
					<p>还没有任何笔记本，先创建一个吧。</p>
				</div>

				<!-- 笔记本卡片瀑布流 -->
				<div class="notebook-masonry hidden" id="notebook-masonry"></div>
			</div>
		</div>
	</div>

	<script>
	import { GALLERY_IMAGES, hashString, getCoverImage } from "@/utils/notebook-covers";
	window.notebookCovers = { GALLERY_IMAGES, hashString, getCoverImage };
	window.escapeText = function(str) {
		const div = document.createElement("div");
		div.textContent = str;
		return div.innerHTML;
	};
	window.formatDate = function(timestamp) {
		const d = new Date(timestamp);
		const y = d.getFullYear();
		const m = String(d.getMonth() + 1).padStart(2, "0");
		const day = String(d.getDate()).padStart(2, "0");
		return y + "-" + m + "-" + day;
	};
</script>

<script is:inline>
	function renderCover(cover, name) {
		var url = notebookCovers.getCoverImage(cover, name);
		return 'style="background-image: url(\'' + escapeText(url) + '\');"';
	}

	function groupByNotebook(entries) {
		var map = new Map();
		for (var i = 0; i < entries.length; i++) {
			var entry = entries[i];
			var list = map.get(entry.notebook) || [];
			list.push(entry);
			map.set(entry.notebook, list);
		}

		var groups = [];
		map.forEach(function(list, name) {
			var sorted = list.sort(function(a, b) { return b.updatedAt - a.updatedAt; });
			var latest = sorted[0];
			var description = latest ? latest.content.slice(0, 80).replace(/[#*`>]/g, "").trim() : "";
			groups.push({
				name: name,
				count: list.length,
				lastUpdated: latest ? latest.updatedAt : 0,
				lastDate: latest ? latest.date : "",
				cover: latest ? latest.cover : "",
				description: description || "暂无描述",
			});
		});

		return groups.sort(function(a, b) { return b.lastUpdated - a.lastUpdated; });
	}

	function renderNotebookCards(groups) {
		var masonry = document.getElementById("notebook-masonry");
		if (!masonry) return;

		masonry.innerHTML = groups.map(function(group) {
			var url = "/notebook/view/?name=" + encodeURIComponent(group.name);
			var coverStyle = renderCover(group.cover, group.name);
			return '<a href="' + url + '" class="notebook-card" data-no-swup ' + coverStyle + '>' +
				'<div class="notebook-card__overlay"></div>' +
				'<div class="notebook-card__body">' +
					'<div class="notebook-card__header">' +
						'<h2 class="notebook-card__name">' + escapeText(group.name) + '</h2>' +
						'<span class="notebook-card__count">' + group.count + ' 篇</span>' +
					'</div>' +
					'<div class="notebook-card__meta">' +
						'<span>最近更新</span>' +
						'<span class="notebook-card__sep">/</span>' +
						'<span>' + (group.lastDate || formatDate(group.lastUpdated)) + '</span>' +
					'</div>' +
					'<p class="notebook-card__desc">' + escapeText(group.description) + '</p>' +
				'</div>' +
			'</a>';
		}).join("");
	}

	// 带超时的 fetch + 自动重试（dev 模式首次编译可能较慢）
	function fetchWithTimeout(url, options, timeoutMs) {
		return new Promise(function(resolve, reject) {
			var controller = new AbortController();
			var timer = setTimeout(function() {
				controller.abort();
				reject(new Error("Request timeout"));
			}, timeoutMs || 8000);
			options = options || {};
			options.signal = controller.signal;
			fetch(url, options)
				.then(function(res) {
					clearTimeout(timer);
					resolve(res);
				})
				.catch(function(err) {
					clearTimeout(timer);
					reject(err);
				});
		});
	}

	function fetchWithRetry(url, options, timeoutMs, retries) {
		return fetchWithTimeout(url, options, timeoutMs).catch(function(err) {
			if (retries > 0) {
				return new Promise(function(resolve) {
					setTimeout(function() { resolve(fetchWithRetry(url, options, timeoutMs, retries - 1)); }, 500);
				});
			}
			throw err;
		});
	}

	function loadNotebooks() {
		var loading = document.getElementById("notebook-loading");
		var empty = document.getElementById("notebook-empty");
		var masonry = document.getElementById("notebook-masonry");

		// dev 模式首次编译 functions 可能较慢，给予 8s 超时 + 2 次重试
		fetchWithRetry("/api/notebook/", { method: "GET" }, 8000, 2)
			.then(function(res) {
				if (!res.ok) throw new Error("Failed to load notebooks");
				return res.json();
			})
			.then(function(data) {
				var entries = data.entries || [];

				if (loading) loading.style.display = "none";

				if (entries.length === 0) {
					if (empty) empty.style.display = "flex";
					return;
				}

				var groups = groupByNotebook(entries);
				renderNotebookCards(groups);
				if (masonry) masonry.style.display = "block";
			})
			.catch(function(err) {
				if (loading) loading.style.display = "none";
				if (empty) {
					empty.style.display = "flex";
					var p = empty.querySelector("p");
					if (p) p.textContent = "加载失败，请稍后重试。";
				}
				console.error("[notebook] load failed:", err);
			});
	}

	// 兼容首次加载：内联脚本可能错过首次 astro:page-load
	// 因此注册监听后立即调用一次兜底
	loadNotebooks();
	document.addEventListener("astro:page-load", loadNotebooks);
	</script>
</MainGridLayout>
