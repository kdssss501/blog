---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import PageTitle from "@/components/common/PageTitle.astro";

const title = "笔记本管理";
const description = "创建、编辑和删除笔记本内容";
---

<MainGridLayout title={title} description={description}>
	<section class="notebook-admin-page">
		<header class="notebook-admin-header">
			<PageTitle title={title} eyebrow="Notebook Admin" />
		</header>

		<div class="notebook-admin-container">
			<!-- 登录区域 -->
			<div id="admin-login" class="admin-login-card">
				<div class="login-icon">
					<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
						<path d="M7 11V7a5 5 0 0 1 10 0v4"/>
					</svg>
				</div>
				<h2 class="login-title">管理登录</h2>
				<p class="login-desc">输入管理密码以访问笔记本管理功能</p>
				<input
					id="admin-password"
					type="password"
					class="login-input"
					placeholder="管理密码"
					maxlength="50"
				/>
				<button id="admin-login-btn" class="login-btn">登录 >></button>
				<div id="login-error" class="login-error" style="display:none;"></div>
			</div>

			<!-- 管理面板（登录后显示） -->
			<div id="admin-panel" class="admin-panel" style="display:none;">
				<!-- 笔记本选择 -->
				<div class="admin-section">
					<div class="section-header">
						<h3 class="section-title">选择笔记本</h3>
						<button id="new-notebook-btn" class="action-btn">+ 新建笔记本</button>
					</div>
					<div id="notebook-selector" class="notebook-selector"></div>
				</div>

				<!-- 编辑器 -->
				<div class="admin-section">
					<div class="section-header">
						<h3 class="section-title">编辑笔记</h3>
						<div class="editor-actions">
							<button id="new-entry-btn" class="action-btn">+ 新建笔记</button>
						</div>
					</div>

					<div id="editor-area" class="editor-area">
						<div class="editor-fields">
							<div class="field-group">
								<label class="field-label" for="entry-title">标题</label>
								<input id="entry-title" type="text" class="field-input" placeholder="笔记标题" maxlength="100" />
							</div>

							<div class="cover-selector">
								<label class="field-label">笔记本封面</label>
								<div class="cover-upload-area">
									<label class="cover-upload-btn">
										📁 上传自定义图片
										<input type="file" id="cover-file-input" accept="image/*">
									</label>
									<div class="cover-preview" id="cover-preview">
										<div class="cover-grad-preview cover-grad-1">?</div>
									</div>
									<button class="cover-clear-btn" id="cover-clear-btn">清除</button>
								</div>
								<div class="cover-gallery" id="cover-gallery">
									<!-- 8个默认渐变选项，动态生成 -->
								</div>
							</div>

							<div class="field-group">
								<label class="field-label" for="entry-date">日期</label>
								<input id="entry-date" type="date" class="field-input" />
							</div>
							<div class="field-group">
								<label class="field-label" for="entry-notebook">笔记本</label>
								<input id="entry-notebook" type="text" class="field-input" placeholder="笔记本名称" maxlength="30" />
							</div>
							<div class="field-group">
								<label class="field-label" for="entry-content">内容（支持 Markdown）</label>
								<textarea id="entry-content" class="field-textarea" placeholder="写下你的笔记内容..." rows="12"></textarea>
							</div>
						</div>

						<div class="editor-preview">
							<h4 class="preview-title">预览</h4>
							<div id="entry-preview" class="preview-content"></div>
						</div>
					</div>

					<div class="editor-footer">
						<button id="save-entry-btn" class="save-btn">保存笔记 >></button>
						<button id="delete-entry-btn" class="delete-btn" style="display:none;">删除</button>
						<button id="cancel-btn" class="cancel-btn">取消</button>
					</div>

					<div id="editor-message" class="editor-message" style="display:none;"></div>
				</div>

				<!-- 笔记列表 -->
				<div class="admin-section">
					<div class="section-header">
						<h3 class="section-title">已有笔记</h3>
					</div>
					<div id="entries-list" class="entries-list"></div>
				</div>
			</div>
		</div>
	</section>

	<script is:inline>
	// 简单密码验证（前端哈希）
	var ADMIN_PASSWORD_HASH = "kdssss2026";
	var currentEntryId = null;
	// 封面状态："" / "default-N" / "data:image/..."
	var currentCover = "";

	function initNotebookAdmin() {
		var loginCard = document.getElementById('admin-login');
		var adminPanel = document.getElementById('admin-panel');
		var passwordInput = document.getElementById('admin-password');
		var loginBtn = document.getElementById('admin-login-btn');
		var loginError = document.getElementById('login-error');

		// 初始化封面图库
		initCoverGallery();

		// 检查是否已登录
		if (sessionStorage.getItem('notebook_admin') === 'true') {
			showAdminPanel();
		}

		loginBtn.addEventListener('click', function() {
			var password = passwordInput.value.trim();
			if (password === ADMIN_PASSWORD_HASH) {
				sessionStorage.setItem('notebook_admin', 'true');
				showAdminPanel();
			} else {
				if (loginError) {
					loginError.textContent = '密码错误，请重试';
					loginError.style.display = 'block';
				}
				passwordInput.value = '';
			}
		});

		passwordInput.addEventListener('keypress', function(e) {
			if (e.key === 'Enter') loginBtn.click();
		});

		function showAdminPanel() {
			if (loginCard) loginCard.style.display = 'none';
			if (adminPanel) adminPanel.style.display = 'block';
			loadNotebooks();
			loadEntries();
		}

		var GALLERY_IMAGES = [
		"1.webp", "2.webp", "3.webp", "4.webp", "5.webp", "6.webp", "7.webp",
		"16.webp", "20.webp", "21.webp", "22.webp", "24.webp", "25.webp",
		"26.webp", "27.webp", "28.webp", "41.webp", "42.webp", "43.webp",
		"44.webp", "50.webp", "80.webp", "100.webp", "101.webp", "102.webp",
		"103.webp", "104.webp", "105.webp", "107.webp", "200.webp", "201.webp",
		"202.webp", "203.webp", "204.webp", "205.webp"
	];

		function initCoverGallery() {
			var gallery = document.getElementById('cover-gallery');
			if (!gallery) return;
			gallery.innerHTML = '';
			for (var i = 0; i < GALLERY_IMAGES.length; i++) {
				(function(index) {
					var item = document.createElement('div');
					item.className = 'cover-gallery-item';
					item.setAttribute('data-cover', 'default-' + (index + 1));
					item.style.backgroundImage = 'url(\'/gallery/gpt-img2-2026/' + GALLERY_IMAGES[index] + '\')';
					item.addEventListener('click', function() {
						currentCover = 'default-' + (index + 1);
						updateCoverPreview();
					});
					gallery.appendChild(item);
				})(i);
			}

			// 上传按钮
			var fileInput = document.getElementById('cover-file-input');
			if (fileInput) {
				fileInput.addEventListener('change', handleCoverFile);
			}

			// 清除按钮
			var clearBtn = document.getElementById('cover-clear-btn');
			if (clearBtn) {
				clearBtn.addEventListener('click', function() {
					currentCover = '';
					if (fileInput) fileInput.value = '';
					updateCoverPreview();
				});
			}
		}

		// 处理封面上传文件
		function handleCoverFile(e) {
			var file = e.target.files && e.target.files[0];
			if (!file) return;
			if (!file.type.startsWith('image/')) {
				showMessage('请选择图片文件', 'error');
				return;
			}

			var reader = new FileReader();
			reader.onload = function(ev) {
				var src = ev.target.result;
				compressImage(src, 800, function(compressedDataUrl) {
					currentCover = compressedDataUrl;
					updateCoverPreview();

					// 检查大小
					var sizeKB = Math.round(compressedDataUrl.length * 0.75 / 1024);
					if (sizeKB > 500) {
						showMessage('封面图片较大（' + sizeKB + 'KB），可能影响加载速度', 'error');
					}
				});
			};
			reader.onerror = function() {
				showMessage('读取文件失败', 'error');
			};
			reader.readAsDataURL(file);
		}

		// 压缩图片到最大宽度
		function compressImage(src, maxWidth, callback) {
			var img = new Image();
			img.onload = function() {
				var canvas = document.createElement('canvas');
				var ctx = canvas.getContext('2d');
				var width = img.width;
				var height = img.height;

				if (width > maxWidth) {
					height = Math.round(height * (maxWidth / width));
					width = maxWidth;
				}

				canvas.width = width;
				canvas.height = height;
				ctx.drawImage(img, 0, 0, width, height);

				// 尝试输出 JPEG，质量 0.85；若失败则回退 PNG
				var result;
				try {
					result = canvas.toDataURL('image/jpeg', 0.85);
				} catch (err) {
					result = canvas.toDataURL('image/png');
				}
				callback(result);
			};
			img.onerror = function() {
				// 压缩失败，回退原图
				callback(src);
			};
			img.src = src;
		}

		// 更新封面预览
		function updateCoverPreview() {
			var preview = document.getElementById('cover-preview');
			if (!preview) return;

			if (currentCover && currentCover.indexOf('data:image/') === 0) {
				preview.style.backgroundImage = 'url(\'' + currentCover + '\')';
				preview.innerHTML = '';
			} else if (currentCover && currentCover.indexOf('default-') === 0) {
				var match = currentCover.match(/^default-(\d+)$/);
				var n = match ? parseInt(match[1], 10) : 1;
				var imgIndex = Math.max(0, Math.min(n - 1, GALLERY_IMAGES.length - 1));
				preview.style.backgroundImage = 'url(\'/gallery/gpt-img2-2026/' + GALLERY_IMAGES[imgIndex] + '\')';
				preview.innerHTML = '<div class="cover-preview-check">✓</div>';
			} else {
				preview.style.backgroundImage = '';
				preview.innerHTML = '<div class="cover-preview-empty">?</div>';
			}

			// 更新图库选中状态
			var galleryItems = document.querySelectorAll('#cover-gallery .cover-gallery-item');
			for (var i = 0; i < galleryItems.length; i++) {
				var item = galleryItems[i];
				if (item.getAttribute('data-cover') === currentCover) {
					item.classList.add('is-selected');
				} else {
					item.classList.remove('is-selected');
				}
			}
		}

		// 笔记本管理
		function loadNotebooks() {
			fetch('/api/notebook/')
				.then(function(res) { return res.json(); })
				.then(function(data) {
					var selector = document.getElementById('notebook-selector');
					if (!selector) return;

					var notebooks = new Map();
					(data.entries || []).forEach(function(entry) {
						notebooks.set(entry.notebook, (notebooks.get(entry.notebook) || 0) + 1);
					});

					if (notebooks.size === 0) {
						selector.innerHTML = '<div class="empty-hint">暂无笔记本，点击上方按钮创建</div>';
						return;
					}

					selector.innerHTML = '';
					notebooks.forEach(function(count, name) {
						var card = document.createElement('div');
						card.className = 'notebook-select-card';
						card.innerHTML = '<span class="nb-name">' + name + '</span><span class="nb-count">' + count + ' 篇</span>';
						card.addEventListener('click', function() {
							document.getElementById('entry-notebook').value = name;
							loadEntries(name);
						});
						selector.appendChild(card);
					});
				})
				.catch(function(err) { console.error('Failed to load notebooks:', err); });
		}

		function loadEntries(notebookName) {
			var url = notebookName
				? '/api/notebook/?notebook=' + encodeURIComponent(notebookName)
				: '/api/notebook/';
			fetch(url)
				.then(function(res) { return res.json(); })
				.then(function(data) {
					var list = document.getElementById('entries-list');
					if (!list) return;

					var entries = data.entries || [];
					if (entries.length === 0) {
						list.innerHTML = '<div class="empty-hint">暂无笔记，点击上方按钮创建</div>';
						return;
					}

					entries.sort(function(a, b) { return new Date(b.date).getTime() - new Date(a.date).getTime(); });

					list.innerHTML = '';
					entries.forEach(function(entry) {
						var card = document.createElement('div');
						card.className = 'entry-list-item';
						var preview = entry.content.substring(0, 80) + '...';
						card.innerHTML =
							'<div class="entry-item-header">' +
								'<span class="entry-item-title">' + entry.title + '</span>' +
								'<span class="entry-item-date">' + entry.date + '</span>' +
							'</div>' +
							'<div class="entry-item-meta">' +
								'<span class="entry-item-nb">' + entry.notebook + '</span>' +
							'</div>' +
							'<div class="entry-item-preview">' + preview + '</div>';
						card.addEventListener('click', function() { editEntry(entry); });
						list.appendChild(card);
					});
				})
				.catch(function(err) { console.error('Failed to load entries:', err); });
		}

		function editEntry(entry) {
			currentEntryId = entry.id;
			currentCover = entry.cover || '';
			document.getElementById('entry-title').value = entry.title;
			document.getElementById('entry-date').value = entry.date;
			document.getElementById('entry-notebook').value = entry.notebook;
			document.getElementById('entry-content').value = entry.content;
			document.getElementById('delete-entry-btn').style.display = 'inline-flex';
			var fileInput = document.getElementById('cover-file-input');
			if (fileInput) fileInput.value = '';
			updateCoverPreview();
			updatePreview();
			var editorArea = document.getElementById('editor-area');
			window.scrollTo({ top: editorArea.offsetTop - 100, behavior: 'smooth' });
		}

		function newEntry() {
			currentEntryId = null;
			currentCover = '';
			document.getElementById('entry-title').value = '';
			document.getElementById('entry-date').value = new Date().toISOString().split('T')[0];
			var nbInput = document.getElementById('entry-notebook');
			if (!nbInput.value) nbInput.value = '每日总结';
			document.getElementById('entry-content').value = '';
			document.getElementById('delete-entry-btn').style.display = 'none';
			var fileInput = document.getElementById('cover-file-input');
			if (fileInput) fileInput.value = '';
			updateCoverPreview();
			updatePreview();
		}

		// 预览
		function updatePreview() {
			var content = document.getElementById('entry-content').value;
			var preview = document.getElementById('entry-preview');
			if (preview) {
				var html = content
					.replace(/&/g, '&amp;')
					.replace(/</g, '&lt;')
					.replace(/>/g, '&gt;')
					.replace(/^### (.+)$/gm, '<h3>$1</h3>')
					.replace(/^## (.+)$/gm, '<h2>$1</h2>')
					.replace(/^# (.+)$/gm, '<h1>$1</h1>')
					.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
					.replace(/\*(.+?)\*/g, '<em>$1</em>')
					.replace(/\n/g, '<br>');
				preview.innerHTML = html || '<span class="preview-empty">预览区域</span>';
			}
		}

		// 保存
		function saveEntry() {
			var title = document.getElementById('entry-title').value.trim();
			var date = document.getElementById('entry-date').value;
			var notebook = document.getElementById('entry-notebook').value.trim();
			var content = document.getElementById('entry-content').value.trim();

			if (!title || !date || !notebook || !content) {
				showMessage('请填写所有必填字段', 'error');
				return;
			}

			var saveBtn = document.getElementById('save-entry-btn');
			saveBtn.textContent = '保存中...';
			saveBtn.disabled = true;

			var method = currentEntryId ? 'PUT' : 'POST';
			var url = currentEntryId ? '/api/notebook/' + currentEntryId + '/' : '/api/notebook/';
			fetch(url, {
				method: method,
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({
					title: title,
					date: date,
					notebook: notebook,
					content: content,
					cover: currentCover
				}),
			})
				.then(function(res) {
					if (!res.ok) {
						return res.json().catch(function() { return {}; }).then(function(err) {
							throw new Error(err.error || '保存失败: ' + res.status);
						});
					}
					return res.json();
				})
				.then(function() {
					showMessage(currentEntryId ? '更新成功！' : '创建成功！', 'success');
					newEntry();
					loadNotebooks();
					loadEntries();
				})
				.catch(function(err) { showMessage(err.message, 'error'); })
				.finally(function() {
					saveBtn.textContent = '保存笔记 >>';
					saveBtn.disabled = false;
				});
		}

		// 删除
		function deleteEntry() {
			if (!currentEntryId) return;
			if (!confirm('确定要删除这条笔记吗？')) return;

			fetch('/api/notebook/' + currentEntryId + '/', { method: 'DELETE' })
				.then(function(res) {
					if (!res.ok) throw new Error('删除失败: ' + res.status);
					showMessage('删除成功！', 'success');
					newEntry();
					loadNotebooks();
					loadEntries();
				})
				.catch(function(err) { showMessage(err.message, 'error'); });
		}

		function showMessage(msg, type) {
			var el = document.getElementById('editor-message');
			if (!el) return;
			el.textContent = msg;
			el.className = 'editor-message ' + type;
			el.style.display = 'block';
			setTimeout(function() { el.style.display = 'none'; }, 3000);
		}

		// 事件绑定
		document.getElementById('save-entry-btn').addEventListener('click', saveEntry);
		document.getElementById('delete-entry-btn').addEventListener('click', deleteEntry);
		document.getElementById('cancel-btn').addEventListener('click', newEntry);
		document.getElementById('new-entry-btn').addEventListener('click', newEntry);
		document.getElementById('new-notebook-btn').addEventListener('click', function() {
			newEntry();
			document.getElementById('entry-notebook').focus();
		});
		document.getElementById('entry-content').addEventListener('input', updatePreview);
	}

	// 兼容首次加载：内联脚本可能错过首次 astro:page-load
	// 因此注册监听后立即调用一次兜底
	initNotebookAdmin();
	document.addEventListener("astro:page-load", initNotebookAdmin);
	</script>
</MainGridLayout>

<style>
	.notebook-admin-page {
		width: 100%;
		padding-top: 0.5rem;
	}

	.notebook-admin-header {
		margin-bottom: 1.5rem;
	}

	.notebook-admin-container {
		max-width: 900px;
		margin: 0 auto;
	}

	/* 登录区域 */
	.admin-login-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
		padding: 3rem 2rem;
		border: 2px solid var(--deep-text);
		border-radius: var(--radius-large);
		background: transparent;
		max-width: 400px;
		margin: 4rem auto;
	}

	.login-icon {
		color: var(--deep-text);
		opacity: 0.6;
	}

	.login-title {
		font-size: 1.5rem;
		font-weight: 800;
		color: var(--deep-text);
	}

	.login-desc {
		font-size: 0.9rem;
		color: var(--content-meta);
		text-align: center;
	}

	.login-input {
		width: 100%;
		padding: 0.75rem 1rem;
		border: 2px solid var(--deep-text);
		border-radius: var(--radius-large);
		background: transparent;
		color: var(--deep-text);
		font-size: 1rem;
		outline: none;
		transition: box-shadow 0.2s ease;
	}

	.login-input:focus {
		box-shadow: 4px 4px 0px var(--deep-text);
	}

	.login-btn {
		width: 100%;
		padding: 0.75rem 1.5rem;
		border: 2px solid var(--deep-text);
		border-radius: var(--radius-large);
		background: var(--deep-text);
		color: var(--page-bg);
		font-size: 1rem;
		font-weight: 700;
		cursor: pointer;
		transition: transform 0.2s ease;
	}

	.login-btn:hover {
		transform: translateY(-2px);
	}

	.login-error {
		color: #e53e3e;
		font-size: 0.9rem;
		font-weight: 700;
	}

	/* 管理面板 */
	.admin-panel {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.admin-section {
		border: 2px solid var(--deep-text);
		border-radius: var(--radius-large);
		padding: 1.5rem;
		background: transparent;
	}

	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1rem;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.section-title {
		font-size: 1.25rem;
		font-weight: 800;
		color: var(--deep-text);
	}

	.action-btn {
		padding: 0.5rem 1rem;
		border: 2px solid var(--deep-text);
		border-radius: var(--radius-large);
		background: transparent;
		color: var(--deep-text);
		font-size: 0.9rem;
		font-weight: 700;
		cursor: pointer;
		transition: all 0.2s ease;
	}

	.action-btn:hover {
		background: var(--deep-text);
		color: var(--page-bg);
	}

	/* 笔记本选择器 */
	.notebook-selector {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
		gap: 0.75rem;
	}

	.notebook-select-card {
		display: flex;
		justify-content: space-between;
