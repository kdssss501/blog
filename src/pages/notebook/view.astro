---
import MainGridLayout from "@/layouts/MainGridLayout.astro";

const title = "笔记本";
---

<MainGridLayout title={title}>
	<div class="notebook-detail-page">
		<div id="notebook-detail-container">
			<div class="notebook-loading" id="notebook-detail-loading">
				<span class="notebook-loading-dot"></span>
				<span>正在加载笔记...</span>
			</div>

			<div class="notebook-empty hidden" id="notebook-detail-error">
				<p>加载失败，请稍后重试。</p>
			</div>

			<div class="notebook-detail-container hidden" id="notebook-detail-content"></div>
		</div>
	</div>

	<script>
		// @ts-nocheck
		import { renderRichContent } from "@/utils/activity-content";
		import { getCoverImage } from "@/utils/notebook-covers";
		import {
			getNotebookEntryMeta,
			getNotebookGroupMeta,
		} from "@/utils/notebook-content";

		/**
		 * @typedef {{
		 *   id: string;
		 *   notebook: string;
		 *   title: string;
		 *   date: string;
		 *   content: string;
		 *   cover: string;
		 *   updatedAt: number;
		 * }} NotebookEntry
		 */

		const detailCache = {
			get(key) {
				try {
					const cached = sessionStorage.getItem("notebook_detail_" + key);
					if (!cached) return null;
					const parsed = /** @type {{ data: { entries: NotebookEntry[] }; timestamp: number }} */ (JSON.parse(cached));
					if (Date.now() - parsed.timestamp < 300000) {
						return parsed.data;
					}
					sessionStorage.removeItem("notebook_detail_" + key);
				} catch {}
				return null;
			},
			set(key, data) {
				try {
					sessionStorage.setItem("notebook_detail_" + key, JSON.stringify({
						data,
						timestamp: Date.now(),
					}));
				} catch {}
			},
		};

		/** @param {string} str */
		function escapeText(str) {
			const div = document.createElement("div");
			div.textContent = str;
			return div.innerHTML;
		}

		/** @param {NotebookEntry[]} entries */
		function sortEntries(entries) {
			return [...entries].sort((a, b) => {
				if (a.date === b.date) return b.updatedAt - a.updatedAt;
				return a.date < b.date ? 1 : -1;
			});
		}

		/** @param {string} name @param {NotebookEntry[]} entries */
		function renderNotebookDetail(name, entries) {
			const sorted = sortEntries(entries);
			const groupMeta = getNotebookGroupMeta(name);
			const latestEntry = sorted[0] || null;
			const latestCover = latestEntry
				? getCoverImage(latestEntry.cover, name)
				: groupMeta.coverImage;
			const latestDate = latestEntry ? escapeText(latestEntry.date) : "暂无";
			const tocHtml = sorted
				.map(function(entry, index) {
					return '<button class="notebook-outline__item" type="button" data-entry-id="' + escapeText(entry.id) + '">' +
						'<span class="notebook-outline__index">' + String(index + 1).padStart(2, "0") + '</span>' +
						'<span class="notebook-outline__text">' +
							'<strong>' + escapeText(entry.title) + '</strong>' +
							'<small>' + escapeText(entry.date) + '</small>' +
						'</span>' +
					'</button>';
				})
				.join("");

			const tagsHtml = (groupMeta.tags || [])
				.map(function(tag) {
					return '<span class="notebook-hero__tag">' + escapeText(tag) + "</span>";
				})
				.join("");

			const articleHtml = sorted
				.map(function(entry, index) {
					const meta = getNotebookEntryMeta(entry);
					const labelsHtml = (meta.labels || [])
						.map(function(label) {
							return '<span class="notebook-entry-card__label">' + escapeText(label) + "</span>";
						})
						.join("");

					return '<article class="notebook-entry-card" id="entry-' + escapeText(entry.id) + '">' +
						'<div class="notebook-entry-card__media">' +
							'<img src="' + escapeText(meta.image) + '" alt="' + escapeText(meta.imageAlt || entry.title) + '" loading="lazy" decoding="async" class="notebook-entry-card__image" />' +
						'</div>' +
						'<div class="notebook-entry-card__body">' +
							'<div class="notebook-entry-card__meta">' +
								'<span class="notebook-entry-card__count">#' + String(index + 1).padStart(2, "0") + "</span>" +
								'<span class="notebook-entry-card__date">' + escapeText(entry.date) + "</span>" +
							"</div>" +
							'<h2 class="notebook-entry-card__title">' + escapeText(entry.title) + "</h2>" +
							'<p class="notebook-entry-card__summary">' + escapeText(meta.summary) + "</p>" +
							'<blockquote class="notebook-entry-card__insight">' + escapeText(meta.insight) + "</blockquote>" +
							(labelsHtml ? '<div class="notebook-entry-card__labels">' + labelsHtml + "</div>" : "") +
							'<div class="notebook-entry-card__content custom-md">' + renderRichContent(entry.content || "") + "</div>" +
						"</div>" +
					"</article>";
				})
				.join("");

			return '<a href="/notebook/" class="notebook-back">← 返回笔记本列表</a>' +
				'<section class="notebook-hero notebook-hero--detail">' +
					'<img src="' + escapeText(groupMeta.coverImage || latestCover) + '" alt="' + escapeText(groupMeta.coverAlt || name) + '" class="notebook-hero__image" loading="eager" decoding="async" />' +
					'<div class="notebook-hero__overlay"></div>' +
					'<div class="notebook-hero__content">' +
						'<span class="notebook-hero__eyebrow">' + escapeText(groupMeta.eyebrow || "Notebook") + "</span>" +
						'<h1 class="notebook-hero__title">' + escapeText(groupMeta.heroTitle || name) + "</h1>" +
						'<p class="notebook-hero__description">' + escapeText(groupMeta.heroDescription || groupMeta.intro || "") + "</p>" +
						'<div class="notebook-hero__meta">' +
							'<span>' + sorted.length + ' 篇笔记</span>' +
							'<span>最近更新 ' + latestDate + "</span>" +
						"</div>" +
						(tagsHtml ? '<div class="notebook-hero__tags">' + tagsHtml + "</div>" : "") +
					"</div>" +
				"</section>" +
				'<section class="notebook-detail-grid">' +
					'<article class="notebook-panel notebook-panel--entries">' +
						'<div class="notebook-panel__header">' +
							'<span class="notebook-panel__eyebrow">Notebook Essays</span>' +
							'<h2 class="notebook-panel__title">这一组笔记的图文记录</h2>' +
							'<p class="notebook-panel__text">' + escapeText(groupMeta.intro || "") + "</p>" +
						"</div>" +
						'<div class="notebook-entry-list">' + articleHtml + "</div>" +
					"</article>" +
					'<aside class="notebook-panel notebook-panel--aside">' +
						'<section class="notebook-side-card">' +
							'<span class="notebook-side-card__eyebrow">Overview</span>' +
							'<h2 class="notebook-side-card__title">' + escapeText(groupMeta.name) + "</h2>" +
							'<p class="notebook-side-card__text">' + escapeText(groupMeta.listDescription || groupMeta.intro || "") + "</p>" +
							'<dl class="notebook-side-card__stats">' +
								"<div><dt>笔记数量</dt><dd>" + sorted.length + " 篇</dd></div>" +
								"<div><dt>最近更新</dt><dd>" + latestDate + "</dd></div>" +
								"<div><dt>主题气质</dt><dd>" + escapeText((groupMeta.tags || []).join(" / ") || "记录中") + "</dd></div>" +
							"</dl>" +
						"</section>" +
						'<section class="notebook-side-card">' +
							'<span class="notebook-side-card__eyebrow">Outline</span>' +
							'<h2 class="notebook-side-card__title">快速跳转</h2>' +
							'<div class="notebook-outline">' + tocHtml + "</div>" +
						"</section>" +
					"</aside>" +
				"</section>";
		}

		/** @param {HTMLElement} root */
		function bindNotebookDetailInteractions(root) {
			const tocItems = root.querySelectorAll("[data-entry-id]");
			for (const item of tocItems) {
				item.addEventListener("click", function() {
					const entryId = item.getAttribute("data-entry-id");
					const target = entryId ? document.getElementById("entry-" + entryId) : null;
					if (target) {
						target.scrollIntoView({ behavior: "smooth", block: "start" });
					}
				});
			}
		}

		/** @param {string} url @param {RequestInit=} options @param {number=} timeoutMs */
		function fetchWithTimeout(url, options, timeoutMs) {
			return /** @type {Promise<Response>} */ (new Promise(function(resolve, reject) {
				const controller = new AbortController();
				const timer = setTimeout(function() {
					controller.abort();
					reject(new Error("Request timeout"));
				}, timeoutMs || 8000);
				fetch(url, { ...(options || {}), signal: controller.signal })
					.then(function(res) {
						clearTimeout(timer);
						resolve(res);
					})
					.catch(function(err) {
						clearTimeout(timer);
						reject(err);
					});
			}));
		}

		async function loadNotebookDetail(forceRefresh = false) {
			const loading = /** @type {HTMLElement | null} */ (document.getElementById("notebook-detail-loading"));
			const error = /** @type {HTMLElement | null} */ (document.getElementById("notebook-detail-error"));
			const content = /** @type {HTMLElement | null} */ (document.getElementById("notebook-detail-content"));
			const params = new URLSearchParams(window.location.search);
			const name = (params.get("name") || "").trim();

			if (!name) {
				if (loading) loading.style.display = "none";
				if (error) {
					error.style.display = "flex";
					const p = error.querySelector("p");
					if (p) p.textContent = "未指定笔记本名称。";
				}
				return;
			}

			if (loading) loading.style.display = "flex";
			if (error) error.style.display = "none";
			if (content) content.style.display = "none";

			if (!forceRefresh) {
				const cached = detailCache.get(name);
				if (cached?.entries?.length && content) {
					if (loading) loading.style.display = "none";
					content.innerHTML = renderNotebookDetail(name, cached.entries);
					content.style.display = "block";
					bindNotebookDetailInteractions(content);
					return;
				}
			}

			try {
				const response = await fetchWithTimeout("/api/notebook/?notebook=" + encodeURIComponent(name), { method: "GET" }, 10000);
				if (!response.ok) throw new Error("Failed to load notebook detail");
				const data = /** @type {{ entries?: NotebookEntry[] }} */ (await response.json());
				const entries = data.entries || [];
				detailCache.set(name, { entries });

				if (loading) loading.style.display = "none";
				if (entries.length === 0) {
					if (error) {
						error.style.display = "flex";
						const p = error.querySelector("p");
						if (p) p.textContent = "这个笔记本还没有内容。";
					}
					return;
				}

				if (content) {
					content.innerHTML = renderNotebookDetail(name, entries);
					content.style.display = "block";
					bindNotebookDetailInteractions(content);
				}
			} catch (err) {
				if (loading) loading.style.display = "none";
				if (error) error.style.display = "flex";
				console.error("[notebook-detail] load failed:", err);
			}
		}

		loadNotebookDetail(false);
		if (window.__notebookDetailPageLoadHandler) {
			document.removeEventListener("astro:page-load", window.__notebookDetailPageLoadHandler);
		}
		if (window.__notebookDetailVisibilityHandler) {
			document.removeEventListener("visibilitychange", window.__notebookDetailVisibilityHandler);
		}
		window.__notebookDetailPageLoadHandler = function() {
			loadNotebookDetail(false);
		};
		window.__notebookDetailVisibilityHandler = function() {
			if (document.visibilityState === "visible") {
				const content = document.getElementById("notebook-detail-content");
				if (!content || content.style.display !== "block") {
					loadNotebookDetail(false);
				}
			}
		};
		document.addEventListener("astro:page-load", window.__notebookDetailPageLoadHandler);
		document.addEventListener("visibilitychange", window.__notebookDetailVisibilityHandler);
	</script>
</MainGridLayout>
