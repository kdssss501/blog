---
import TreeholeCompose from "@components/features/TreeholeCompose.svelte";
import TreeholeList from "@components/features/TreeholeList.svelte";
import PageTitle from "@/components/common/PageTitle.astro";
import { siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

// 检查页面是否启用
if (!siteConfig.pages.treehole) {
	return Astro.redirect("/404/");
}

const title = i18n(I18nKey.treehole);
const description = i18n(I18nKey.treeholeDescription);
---

<MainGridLayout title={title} description={description}>
	<div class="flex w-full rounded-(--radius-large) relative min-h-32">
		<div class="card-base z-10 px-4 py-6 md:px-9 relative w-full">
			<!-- 页面标题 -->
			<div class="mb-6">
				<PageTitle title={title} eyebrow="Treehole" variant="stacked" />
				{description && (
					<p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed mt-3">
						{description}
					</p>
				)}
			</div>

			<!-- 匿名倾诉区 -->
			<div class="treehole-compose-wrap mb-8">
				<TreeholeCompose client:load />
			</div>

			<!-- 树洞列表 -->
			<div class="section-label mb-4">[ 倾听树洞 ]</div>
			<TreeholeList client:only="svelte">
				<div slot="fallback" class="flex items-center justify-center" style="min-height: 40vh;">
					<div class="text-neutral-400 dark:text-neutral-500 text-sm animate-pulse">正在聆听树洞...</div>
				</div>
			</TreeholeList>
		</div>
	</div>
</MainGridLayout>
