---
import TreeholeAdminPanel from "@components/features/TreeholeAdmin.svelte";
import PageTitle from "@/components/common/PageTitle.astro";
import { siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

// 检查页面是否启用
if (!siteConfig.pages.treehole) {
	return Astro.redirect("/404/");
}

const title = i18n(I18nKey.treeholeAdmin);
---

<MainGridLayout title={title}>
	<div class="flex w-full rounded-(--radius-large) relative min-h-32">
		<div class="card-base z-10 px-4 py-6 md:px-9 relative w-full">
			<div class="mb-6">
				<PageTitle title={title} eyebrow="Admin" variant="stacked" />
			</div>
			<TreeholeAdminPanel client:only="svelte">
				<div slot="fallback" class="flex items-center justify-center" style="min-height: 40vh;">
					<div class="text-neutral-400 dark:text-neutral-500 text-sm animate-pulse">加载中...</div>
				</div>
			</TreeholeAdminPanel>
		</div>
	</div>
</MainGridLayout>
