---
import PageTitle from "@/components/common/PageTitle.astro";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

const title = "动态";
const description = "记录日常点滴，分享生活感悟。";
---

<MainGridLayout title={title} description={description} showSidebar={true}>
	<div class="activity-page">
		<div class="activity-page__header">
			<PageTitle title={title} eyebrow="Activity" variant="stacked" />
			{description && (
				<p class="activity-page__desc">{description}</p>
			)}
		</div>

		<div id="activity-list-container">
			<div class="activity-loading" id="activity-loading">
				<span class="activity-loading-dot"></span>
				<span>正在加载动态...</span>
			</div>

			<div class="activity-empty hidden" id="activity-empty">
				<p>还没有任何动态，分享你的第一条动态吧。</p>
			</div>

			<div class="activity-list hidden" id="activity-list"></div>
		</div>
	</div>

	<script is:inline>
		var ACTIVITY_CACHE_VERSION = "cards-v3";

		var activityCache = {
			ttl: 180000,
			getStorageKey: function(key) {
				return "activity_" + ACTIVITY_CACHE_VERSION + "_" + key;
			},
			get: function(key) {
				try {
					var cached = sessionStorage.getItem(this.getStorageKey(key));
					if (!cached) return null;
					var parsed = JSON.parse(cached);
					if (Date.now() - parsed.timestamp < this.ttl) {
						return validateActivityPayload(parsed.data) ? parsed.data : null;
					}
					sessionStorage.removeItem(this.getStorageKey(key));
					return null;
				} catch (e) {
					return null;
				}
			},
			set: function(key, data) {
			try {
				sessionStorage.setItem(this.getStorageKey(key), JSON.stringify({
					data: data,
					timestamp: Date.now()
				}));
			} catch (e) {}
		}
		};

		function validateActivityItem(item) {
		if (!item || typeof item !== "object") return false;
		var slug = typeof item.slug === "string" ? item.slug.trim() : "";
		var title = typeof item.title === "string" ? item.title.trim() : "";
		return !!(slug && title);
	}

		function validateActivityPayload(data) {
			return !!(data && Array.isArray(data.items) && data.items.length > 0 && data.items.every(validateActivityItem));
		}

		function escapeText(str) {
			const div = document.createElement("div");
			div.textContent = str;
			return div.innerHTML;
		}

		function formatDate(timestamp) {
			const d = new Date(timestamp);
			const y = d.getFullYear();
			const m = String(d.getMonth() + 1).padStart(2, "0");
			const day = String(d.getDate()).padStart(2, "0");
			const h = String(d.getHours()).padStart(2, "0");
			const min = String(d.getMinutes()).padStart(2, "0");
			return y + "-" + m + "-" + day + " " + h + ":" + min;
		}

		function renderActivityItem(item) {
			const url = "/activity/view/?slug=" + encodeURIComponent(item.slug);
			const coverImage = (item.coverImage || (item.images && item.images[0] && item.images[0].url) || item.image || "").trim();
			const excerpt = item.excerpt || item.content || "";
			return '<article class="activity-card">' +
				'<a href="' + url + '" class="activity-card__surface" aria-label="查看动态详情：' + escapeText(item.title || "未命名动态") + '">' +
				'<div class="activity-card__header">' +
					'<div class="activity-card__title-wrap">' +
						'<span class="activity-card__time">' + formatDate(item.createdAt) + '</span>' +
						'<h2 class="activity-card__title">' + escapeText(item.title || "未命名动态") + '</h2>' +
					'</div>' +
					'<div class="activity-card__header-side">' +
						(coverImage ? '<div class="activity-card__thumb"><img src="' + escapeText(coverImage) + '" class="activity-card__thumb-image" alt="' + escapeText(item.title || "动态缩略图") + '" loading="lazy" decoding="async" /></div>' : '') +
						'<span class="activity-card__arrow" aria-hidden="true">' +
						'<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>' +
						'</span>' +
					'</div>' +
				'</div>' +
				'<div class="activity-card__body">' +
					'<p>' + escapeText(excerpt) + '</p>' +
				'</div>' +
				'<span class="activity-card__link">查看详情 →</span>' +
				'</a>' +
				'</article>';
		}

		function renderActivityList(items) {
			const list = document.getElementById("activity-list");
			if (!list) return;

			list.innerHTML = items.map(function(item) {
				return renderActivityItem(item);
			}).join("");
			preloadActivityImages(items);
		}

		function preloadActivityImages(items) {
			(items || []).slice(0, 4).forEach(function(item) {
				var coverImage = (item.coverImage || (item.images && item.images[0] && item.images[0].url) || item.image || "").trim();
				if (!coverImage) return;
				var img = new Image();
				img.decoding = "async";
				img.src = coverImage;
			});
		}

		function fetchWithTimeout(url, options, timeoutMs) {
			return new Promise(function(resolve, reject) {
				var controller = new AbortController();
				var timer = setTimeout(function() {
					controller.abort();
					reject(new Error("Request timeout"));
				}, timeoutMs || 10000);
				options = options || {};
				options.signal = controller.signal;
				fetch(url, options)
					.then(function(res) {
						clearTimeout(timer);
						resolve(res);
					})
					.catch(function(err) {
						clearTimeout(timer);
						reject(err);
					});
			});
		}

		function fetchWithExponentialRetry(url, options, timeoutMs, maxRetries) {
			return new Promise(function(resolve, reject) {
				var attempts = 0;
				var delay = 500;

				function attempt() {
					fetchWithTimeout(url, options, timeoutMs)
						.then(resolve)
						.catch(function(err) {
							attempts++;
							if (attempts <= maxRetries) {
								setTimeout(attempt, delay);
								delay = delay * 2;
							} else {
								reject(err);
							}
						});
				}

				attempt();
			});
		}

		var isLoading = false;
		var activityRequestPromise = null;

		function fetchActivitiesData() {
			if (activityRequestPromise) return activityRequestPromise;
			activityRequestPromise = fetchWithExponentialRetry("/api/activity/", { method: "GET" }, 10000, 3)
				.then(function(res) {
					if (!res.ok) throw new Error("Failed to load activities");
					return res.json();
				})
				.then(function(data) {
					if (!validateActivityPayload(data)) {
						throw new Error("Received stale activity payload");
					}
					activityCache.set("list", data);
					return data;
				})
				.finally(function() {
					activityRequestPromise = null;
				});
			return activityRequestPromise;
		}

		function loadActivities(forceRefresh, options) {
			if (isLoading) return;
			isLoading = true;
			options = options || {};

			var loading = document.getElementById("activity-loading");
			var empty = document.getElementById("activity-empty");
			var list = document.getElementById("activity-list");

			if (!options.preserveList) {
				if (loading) loading.style.display = "flex";
				if (empty) empty.style.display = "none";
				if (list) list.style.display = "none";
			}

			if (!forceRefresh) {
				var cachedData = activityCache.get("list");
				if (validateActivityPayload(cachedData)) {
					processActivityData(cachedData, loading, empty, list);
					if (!options.skipRefresh) {
						fetchActivitiesData()
							.then(function(data) {
								processActivityData(data, loading, empty, list);
							})
							.catch(function(err) {
								console.error("[activity] background refresh failed:", err);
							})
							.finally(function() {
								isLoading = false;
							});
						return;
					}
					isLoading = false;
					return;
				}
			}

			fetchActivitiesData()
				.then(function(data) {
					processActivityData(data, loading, empty, list);
				})
				.catch(function(err) {
					if (loading) loading.style.display = "none";
					if (empty) {
						empty.style.display = "flex";
						var p = empty.querySelector("p");
						if (p) p.textContent = "加载失败，点击重试";
						empty.style.cursor = "pointer";
						empty.onclick = function() { loadActivities(true); };
					}
					console.error("[activity] load failed:", err);
				})
				.finally(function() {
					isLoading = false;
				});
		}

		function processActivityData(data, loading, empty, list) {
			var items = data.items || [];

			if (loading) loading.style.display = "none";

			if (items.length === 0) {
				if (empty) {
					empty.style.display = "flex";
					var p = empty.querySelector("p");
					if (p) p.textContent = "还没有任何动态，分享你的第一条动态吧。";
					empty.style.cursor = "default";
					empty.onclick = null;
				}
				return;
			}

			renderActivityList(items);
			if (list) list.style.display = "flex";
		}

		function handleVisibilityChange() {
			if (document.visibilityState === "visible") {
				var list = document.getElementById("activity-list");
				if (!list || list.style.display !== "flex") {
					loadActivities(false, { preserveList: false });
				}
			}
		}

		function initializeActivityPage() {
			var list = document.getElementById("activity-list");
			if (!list || !list.children.length) {
				loadActivities(false, { preserveList: false });
				return;
			}
			loadActivities(false, { preserveList: true, skipRefresh: false });
		}

		initializeActivityPage();
		requestAnimationFrame(function() {
			var list = document.getElementById("activity-list");
			if (!list || !list.children.length) {
				loadActivities(false, { preserveList: false });
			}
		});

		if (window.__activityPageLoadHandler) {
			document.removeEventListener("astro:page-load", window.__activityPageLoadHandler);
		}
		if (window.__activityPageVisibilityHandler) {
			document.removeEventListener("visibilitychange", window.__activityPageVisibilityHandler);
		}
		window.__activityPageLoadHandler = function() { initializeActivityPage(); };
		window.__activityPageVisibilityHandler = handleVisibilityChange;
		document.addEventListener("astro:page-load", window.__activityPageLoadHandler);
		document.addEventListener("visibilitychange", handleVisibilityChange);
		window.addEventListener("pageshow", function() {
			var list = document.getElementById("activity-list");
			if (!list || !list.children.length) {
				loadActivities(false, { preserveList: false });
			}
		}, { once: true });
	</script>
</MainGridLayout>

<style is:global>
	.activity-page {
		width: 100%;
		--page-bg: #fff;
		--card-bg: #fff;
		padding: 0.5rem 0 0;
	}

	.activity-page__header {
		margin-bottom: 1.5rem;
		padding: 1.35rem 1.5rem;
		border: 2px solid color-mix(in oklch, var(--deep-text) 14%, transparent);
		border-radius: var(--radius-xl);
		background: linear-gradient(180deg, #fff 0%, #fafaf9 100%);
		box-shadow: 0 16px 48px -32px color-mix(in oklch, var(--deep-text) 20%, transparent);
	}

	.activity-page__desc {
		font-size: 0.95rem;
		color: var(--content-meta);
		line-height: 1.6;
		margin-top: 0.75rem;
		font-weight: 700;
	}

	/* === Loading === */
	.activity-loading {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		padding: 4rem;
		color: var(--content-meta);
		font-weight: 700;
	}

	.activity-loading-dot {
		width: 0.75rem;
		height: 0.75rem;
		border-radius: 50%;
		background: var(--deep-text);
		animation: activity-bounce 1s infinite;
	}

	@keyframes activity-bounce {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-0.5rem); }
	}

	/* === Empty === */
	.activity-empty {
		display: none;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		padding: 6rem 0;
		text-align: center;
	}

	.activity-empty p {
		color: var(--content-meta);
		font-size: 0.95rem;
		font-weight: 700;
		margin: 0;
	}

	/* === Firefly 卡片列表 === */
	.activity-list {
		display: none;
		flex-direction: column;
		gap: 1.25rem;
	}

	/* === Firefly 卡片组件 === */
	.activity-card {
		border: 2px solid color-mix(in oklch, var(--deep-text) 12%, transparent);
		border-radius: var(--radius-xl);
		background:
			linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(248,248,247,0.98) 100%);
		box-shadow: 0 18px 40px -30px color-mix(in oklch, var(--deep-text) 24%, transparent);
		transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease, background-color 0.3s ease;
		position: relative;
		overflow: hidden;
		content-visibility: auto;
		contain-intrinsic-size: 230px;
	}

	.activity-card__surface {
		display: block;
		padding: 1.5rem 1.5rem 1.35rem;
		color: inherit;
		text-decoration: none;
	}

	.activity-card:hover {
		transform: translateY(-5px);
		border-color: var(--deep-text);
		box-shadow: 0 24px 48px -26px color-mix(in oklch, var(--deep-text) 26%, transparent);
	}

	:root.dark .activity-card:hover {
		border-color: #fff;
		box-shadow: 0 12px 32px -8px color-mix(in oklch, #fff 18%, transparent);
	}

	/* === Card Header === */
	.activity-card__header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1rem;
		padding-bottom: 1rem;
		border-bottom: 1px solid color-mix(in oklch, var(--deep-text) 10%, transparent);
	}

	.activity-card__title-wrap {
		min-width: 0;
		flex: 1;
	}

	.activity-card__time {
		display: inline-block;
		font-size: 0.75rem;
		font-weight: 700;
		color: var(--content-meta);
		font-family: ui-monospace, SFMono-Regular, monospace;
		letter-spacing: 0.02em;
	}

	.activity-card__title {
		margin: 0.5rem 0 0;
		font-size: 1.12rem;
		font-weight: 800;
		line-height: 1.35;
		color: var(--deep-text);
	}

	.activity-card__header-side {
		display: flex;
		align-items: flex-end;
		gap: 0.75rem;
		flex-shrink: 0;
	}

	.activity-card__thumb {
		width: 5.25rem;
		height: 5.25rem;
		border-radius: 0.9rem;
		overflow: hidden;
		border: 1px solid color-mix(in oklch, var(--deep-text) 12%, transparent);
		background: color-mix(in oklch, var(--deep-text) 4%, #fff);
		box-shadow: inset 0 0 0 1px rgba(255,255,255,0.4);
	}

	.activity-card__thumb-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	/* === Hover Arrow (like post-card-arrow) === */
	.activity-card__arrow {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		border-radius: 9999px;
		background: var(--deep-text);
		color: var(--page-bg);
		opacity: 0;
		transform: translate(0.25rem, 0.25rem);
		transition: opacity 0.25s ease, transform 0.25s ease, background-color 0.25s ease;
		flex-shrink: 0;
	}

	.activity-card:hover .activity-card__arrow {
		opacity: 1;
		transform: translate(0, 0);
		background: var(--deep-text);
	}

	:root.dark .activity-card__arrow {
		background: var(--deep-text);
		color: var(--page-bg);
	}

	:root.dark .activity-card:hover .activity-card__arrow {
		background: #fff;
	}

	/* === Card Body === */
	.activity-card__body {
		margin-bottom: 1rem;
		position: relative;
		min-height: 4.2rem;
	}

	.activity-card__body p {
		margin: 0;
		font-size: 0.95rem;
		line-height: 1.7;
		color: var(--deep-text);
		white-space: pre-wrap;
		word-break: break-word;
		overflow: hidden;
		text-overflow: ellipsis;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
	}

	.activity-card__link {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		padding-top: 0.15rem;
		font-size: 0.75rem;
		font-weight: 700;
		color: var(--deep-text);
		transition: color 0.15s, gap 0.15s;
	}

	:root.dark .activity-card__link {
		color: #fff;
	}

	.activity-card__link:hover {
		color: color-mix(in oklch, var(--deep-text) 85%, var(--page-bg));
		gap: 0.5rem;
	}

	:root.dark .activity-card__link:hover {
		color: color-mix(in oklch, #fff 90%, transparent);
		gap: 0.5rem;
	}

	@media (max-width: 768px) {
		.activity-card {
		}

		.activity-card__surface {
			padding: 1.25rem;
		}

		.activity-card__header {
			gap: 0.75rem;
		}

		.activity-card__body p {
			font-size: 0.9rem;
			-webkit-line-clamp: 4;
		}

		.activity-card__thumb {
			width: 4.25rem;
			height: 4.25rem;
		}

		.activity-card__title {
			font-size: 1rem;
		}
	}
</style>
