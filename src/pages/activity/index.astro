---
import PageTitle from "@/components/common/PageTitle.astro";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

const title = "动态";
const description = "记录日常点滴，分享生活感悟。";
---

<MainGridLayout title={title} description={description} showSidebar={true}>
	<div class="activity-page">
		<div class="activity-page__header">
			<PageTitle title={title} eyebrow="Activity" variant="stacked" />
			{description && (
				<p class="activity-page__desc">{description}</p>
			)}
		</div>

		<div id="activity-list-container">
			<div class="activity-loading" id="activity-loading">
				<span class="activity-loading-dot"></span>
				<span>正在加载动态...</span>
			</div>

			<div class="activity-empty hidden" id="activity-empty">
				<p>还没有任何动态，分享你的第一条动态吧。</p>
			</div>

			<div class="activity-list hidden" id="activity-list"></div>
		</div>
	</div>

	<script is:inline>
		function escapeText(str) {
			const div = document.createElement("div");
			div.textContent = str;
			return div.innerHTML;
		}

		function formatDate(timestamp) {
			const d = new Date(timestamp);
			const y = d.getFullYear();
			const m = String(d.getMonth() + 1).padStart(2, "0");
			const day = String(d.getDate()).padStart(2, "0");
			const h = String(d.getHours()).padStart(2, "0");
			const min = String(d.getMinutes()).padStart(2, "0");
			return y + "-" + m + "-" + day + " " + h + ":" + min;
		}

		function renderActivityItem(item) {
			const url = "/activity/" + encodeURIComponent(item.slug);
			return '<article class="activity-card">' +
				'<div class="activity-card__header">' +
					'<span class="activity-card__time">' + formatDate(item.createdAt) + '</span>' +
					'<a href="' + url + '" class="activity-card__arrow" data-no-swup aria-label="查看详情">' +
						'<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>' +
					'</a>' +
				'</div>' +
				'<div class="activity-card__body">' +
					'<p>' + escapeText(item.content) + '</p>' +
				'</div>' +
				'<a href="' + url + '" class="activity-card__link" data-no-swup>查看详情 →</a>' +
			'</article>';
		}

		function renderActivityList(items) {
			const list = document.getElementById("activity-list");
			if (!list) return;

			list.innerHTML = items.map(function(item) {
				return renderActivityItem(item);
			}).join("");
		}

		function fetchWithTimeout(url, options, timeoutMs) {
			return new Promise(function(resolve, reject) {
				var controller = new AbortController();
				var timer = setTimeout(function() {
					controller.abort();
					reject(new Error("Request timeout"));
				}, timeoutMs || 8000);
				options = options || {};
				options.signal = controller.signal;
				fetch(url, options)
					.then(function(res) {
						clearTimeout(timer);
						resolve(res);
					})
					.catch(function(err) {
						clearTimeout(timer);
						reject(err);
					});
			});
		}

		function fetchWithRetry(url, options, timeoutMs, retries) {
			return fetchWithTimeout(url, options, timeoutMs).catch(function(err) {
				if (retries > 0) {
					return new Promise(function(resolve) {
						setTimeout(function() { resolve(fetchWithRetry(url, options, timeoutMs, retries - 1)); }, 500);
					});
				}
				throw err;
			});
		}

		function loadActivities() {
			var loading = document.getElementById("activity-loading");
			var empty = document.getElementById("activity-empty");
			var list = document.getElementById("activity-list");

			fetchWithRetry("/api/activity/", { method: "GET" }, 8000, 2)
				.then(function(res) {
					if (!res.ok) throw new Error("Failed to load activities");
					return res.json();
				})
				.then(function(data) {
					var items = data.items || [];

					if (loading) loading.style.display = "none";

					if (items.length === 0) {
						if (empty) empty.style.display = "flex";
						return;
					}

					renderActivityList(items);
					if (list) list.style.display = "flex";
				})
				.catch(function(err) {
					if (loading) loading.style.display = "none";
					if (empty) {
						empty.style.display = "flex";
						var p = empty.querySelector("p");
						if (p) p.textContent = "加载失败，请稍后重试。";
					}
					console.error("[activity] load failed:", err);
				});
		}

		loadActivities();
		document.addEventListener("astro:page-load", loadActivities);
	</script>
</MainGridLayout>

<style>
	.activity-page {
		width: 100%;
	}

	.activity-page__header {
		margin-bottom: 1.5rem;
	}

	.activity-page__desc {
		font-size: 0.95rem;
		color: var(--content-meta);
		line-height: 1.6;
		margin-top: 0.75rem;
		font-weight: 700;
	}

	/* === Loading === */
	.activity-loading {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		padding: 4rem;
		color: var(--content-meta);
		font-weight: 700;
	}

	.activity-loading-dot {
		width: 0.75rem;
		height: 0.75rem;
		border-radius: 50%;
		background: var(--deep-text);
		animation: activity-bounce 1s infinite;
	}

	@keyframes activity-bounce {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-0.5rem); }
	}

	/* === Empty === */
	.activity-empty {
		display: none;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		padding: 6rem 0;
		text-align: center;
	}

	.activity-empty p {
		color: var(--content-meta);
		font-size: 0.95rem;
		font-weight: 700;
		margin: 0;
	}

	/* === Firefly 卡片列表 === */
	.activity-list {
		display: none;
		flex-direction: column;
		gap: 1rem;
	}

	/* === Firefly 卡片组件 === */
	.activity-card {
		border: 2px solid var(--deep-text);
		border-radius: var(--radius-large);
		padding: 1.25rem 1.5rem;
		background: transparent;
		transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
		position: relative;
	}

	.activity-card:hover {
		transform: translateY(-2px);
		border-color: var(--primary);
		box-shadow: 0 8px 24px -8px color-mix(in oklch, var(--deep-text) 25%, transparent);
	}

	:root.dark .activity-card:hover {
		border-color: var(--primary);
		box-shadow: 0 8px 24px -8px color-mix(in oklch, var(--primary) 30%, transparent);
	}

	/* === Card Header === */
	.activity-card__header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 0.75rem;
	}

	.activity-card__time {
		font-size: 0.75rem;
		font-weight: 700;
		color: var(--content-meta);
		font-family: ui-monospace, SFMono-Regular, monospace;
		letter-spacing: 0.02em;
	}

	/* === Hover Arrow (like post-card-arrow) === */
	.activity-card__arrow {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		border-radius: 9999px;
		background: var(--deep-text);
		color: var(--page-bg);
		opacity: 0;
		transform: translate(0.25rem, 0.25rem);
		transition: opacity 0.25s ease, transform 0.25s ease, background-color 0.25s ease;
		text-decoration: none;
		flex-shrink: 0;
	}

	.activity-card:hover .activity-card__arrow {
		opacity: 1;
		transform: translate(0, 0);
		background: var(--primary);
	}

	:root.dark .activity-card__arrow {
		background: var(--deep-text);
		color: var(--page-bg);
	}

	:root.dark .activity-card:hover .activity-card__arrow {
		background: var(--primary);
	}

	/* === Card Body === */
	.activity-card__body {
		margin-bottom: 0.75rem;
	}

	.activity-card__body p {
		margin: 0;
		font-size: 0.9rem;
		line-height: 1.7;
		color: var(--deep-text);
		white-space: pre-wrap;
		word-break: break-word;
		overflow: hidden;
		text-overflow: ellipsis;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
	}

	/* === Card Link === */
	.activity-card__link {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		font-size: 0.75rem;
		font-weight: 700;
		color: var(--primary);
		text-decoration: none;
		transition: color 0.15s, gap 0.15s;
	}

	.activity-card__link:hover {
		color: var(--primary-hover);
		gap: 0.5rem;
	}

	@media (max-width: 768px) {
		.activity-card {
			padding: 1rem 1.25rem;
		}

		.activity-card__body p {
			font-size: 0.85rem;
			-webkit-line-clamp: 4;
		}
	}
</style>
