---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
---

<MainGridLayout title="动态详情" description="查看动态详情" showSidebar={true}>
	<div class="activity-detail-page">
		<a href="/activity/" class="activity-back-link mb-6 inline-flex items-center gap-0.375rem" data-no-swup>
			<span class="activity-back-icon">←</span>
			<span class="activity-back-text">返回动态列表</span>
		</a>

		<div id="activity-detail-container">
			<div class="activity-detail-loading" id="activity-detail-loading">
				<span class="activity-detail-loading-dot"></span>
				<span>正在加载动态...</span>
			</div>

			<div class="activity-detail-error hidden" id="activity-detail-error">
				<p>加载失败，请稍后重试。</p>
			</div>

			<div class="activity-detail-content hidden" id="activity-detail-content"></div>
		</div>
	</div>

	<script is:inline>
		function escapeText(str) {
			const div = document.createElement("div");
			div.textContent = str;
			return div.innerHTML;
		}

		function getActivitySlug() {
			var params = new URLSearchParams(window.location.search);
			var fromQuery = (params.get("slug") || "").trim();
			if (fromQuery) return fromQuery;
			var segments = window.location.pathname.split("/").filter(Boolean);
			return segments.length > 0 ? segments[segments.length - 1] : "";
		}

		function formatDate(timestamp) {
			const d = new Date(timestamp);
			const y = d.getFullYear();
			const m = String(d.getMonth() + 1).padStart(2, "0");
			const day = String(d.getDate()).padStart(2, "0");
			const h = String(d.getHours()).padStart(2, "0");
			const min = String(d.getMinutes()).padStart(2, "0");
			return y + "-" + m + "-" + day + " " + h + ":" + min;
		}

		function renderActivityDetail(item) {
			const images = Array.isArray(item.images) ? item.images : [];
			return '<article class="activity-detail">' +
				'<header class="activity-detail__header">' +
					'<div class="activity-detail__info">' +
						'<span class="activity-detail__name">Activity Note</span>' +
						'<h1 class="activity-detail__title">' + escapeText(item.title || "未命名动态") + '</h1>' +
						'<span class="activity-detail__time">' + formatDate(item.createdAt) + '</span>' +
					'</div>' +
				'</header>' +
				'<div class="activity-detail__content">' +
					(item.html || ('<p>' + escapeText(item.content || "") + '</p>')) +
				'</div>' +
				(images.length > 0 ? '<section class="activity-detail__gallery">' +
					images.map(function(image, index) {
						return '<figure class="activity-detail__gallery-item">' +
							'<img src="' + escapeText(image.url) + '" alt="' + escapeText(image.alt || (item.title || "动态图片") + " " + (index + 1)) + '" loading="lazy" decoding="async" />' +
						'</figure>';
					}).join("") +
				'</section>' : '') +
				'<footer class="activity-detail__footer">' +
					'<span class="activity-detail__updated">更新于 ' + formatDate(item.updatedAt) + '</span>' +
				'</footer>' +
			'</article>';
		}

		function fetchWithTimeout(url, options, timeoutMs) {
			return new Promise(function(resolve, reject) {
				var controller = new AbortController();
				var timer = setTimeout(function() {
					controller.abort();
					reject(new Error("Request timeout"));
				}, timeoutMs || 8000);
				options = options || {};
				options.signal = controller.signal;
				fetch(url, options)
					.then(function(res) {
						clearTimeout(timer);
						resolve(res);
					})
					.catch(function(err) {
						clearTimeout(timer);
						reject(err);
					});
			});
		}

		function fetchWithRetry(url, options, timeoutMs, retries) {
			return fetchWithTimeout(url, options, timeoutMs).catch(function(err) {
				if (retries > 0) {
					return new Promise(function(resolve) {
						setTimeout(function() { resolve(fetchWithRetry(url, options, timeoutMs, retries - 1)); }, 500);
					});
				}
				throw err;
			});
		}

		function loadActivityDetail() {
			var loading = document.getElementById("activity-detail-loading");
			var error = document.getElementById("activity-detail-error");
			var content = document.getElementById("activity-detail-content");
			var slug = getActivitySlug();
			if (window._closeLive2DWidget) window._closeLive2DWidget();

			if (loading) loading.style.display = "flex";
			if (error) error.style.display = "none";
			if (content) content.style.display = "none";

			if (!slug) {
				if (loading) loading.style.display = "none";
				if (error) {
					error.style.display = "flex";
					var emptySlugMessage = error.querySelector("p");
					if (emptySlugMessage) emptySlugMessage.textContent = "未找到动态标识。";
				}
				return;
			}

			fetchWithRetry("/api/activity/?slug=" + encodeURIComponent(slug), { method: "GET" }, 8000, 2)
				.then(function(res) {
					if (!res.ok) throw new Error("Failed to load activity");
					return res.json();
				})
				.then(function(data) {
					if (loading) loading.style.display = "none";

					if (data.error) {
						if (error) {
							error.style.display = "flex";
							var errorMessage = error.querySelector("p");
							if (errorMessage) errorMessage.textContent = data.error;
						}
						return;
					}

					if (content) {
						content.innerHTML = renderActivityDetail(data);
						content.style.display = "block";
					}
				})
				.catch(function(err) {
					if (loading) loading.style.display = "none";
					if (error) error.style.display = "flex";
					console.error("[activity-detail] load failed:", err);
				});
		}

		loadActivityDetail();
		if (window.__activityDetailPageLoadHandler) {
			document.removeEventListener("astro:page-load", window.__activityDetailPageLoadHandler);
		}
		window.__activityDetailPageLoadHandler = loadActivityDetail;
		document.addEventListener("astro:page-load", window.__activityDetailPageLoadHandler);
	</script>
</MainGridLayout>

<style is:global>
	.activity-detail-page {
		width: 100%;
		--page-bg: #fff;
		--card-bg: #fff;
	}

	.activity-detail-page ~ #live2d-widget,
	.activity-detail-page ~ #live2d-trigger,
	.activity-detail-page ~ #pio-container,
	body:has(.activity-detail-page) #live2d-widget,
	body:has(.activity-detail-page) #live2d-trigger {
		display: none !important;
	}

	.activity-back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		padding: 0.5rem 1rem;
		font-size: 0.85rem;
		font-weight: 700;
		color: var(--deep-text);
		background: transparent;
		border: 2px solid var(--deep-text);
		border-radius: var(--radius-large);
		text-decoration: none;
		transition: background-color 0.15s, color 0.15s;
	}

	.activity-back-link:hover {
		background: var(--deep-text);
		color: var(--page-bg);
	}

	.activity-back-icon {
		font-size: 1.1rem;
	}

	.activity-back-text {
		white-space: nowrap;
	}

	.activity-detail-loading {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		padding: 4rem;
		color: var(--content-meta);
		font-weight: 700;
	}

	.activity-detail-loading-dot {
		width: 0.75rem;
		height: 0.75rem;
		border-radius: 50%;
		background: var(--deep-text);
		animation: activity-bounce 1s infinite;
	}

	@keyframes activity-bounce {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-0.5rem); }
	}

	.activity-detail-error {
		display: none;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		padding: 6rem 0;
		text-align: center;
	}

	.activity-detail-error p {
		color: var(--content-meta);
		font-size: 0.95rem;
		font-weight: 700;
		margin: 0;
	}

	.activity-detail-content {
		display: none;
	}

	.activity-detail {
		position: relative;
		border-radius: var(--radius-large);
		border: 2px solid var(--deep-text);
		background: var(--page-bg);
		padding: 2rem;
	}

	.activity-detail__header {
		margin-bottom: 1.5rem;
	}

	.activity-detail__info {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}

	.activity-detail__name {
		font-size: 0.85rem;
		font-weight: 800;
		color: var(--content-meta);
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.activity-detail__title {
		margin: 0;
		font-size: clamp(1.5rem, 3vw, 2.2rem);
		font-weight: 900;
		line-height: 1.15;
		color: var(--deep-text);
	}

	.activity-detail__time {
		font-size: 0.8rem;
		font-weight: 700;
		color: var(--content-meta);
		font-family: ui-monospace, SFMono-Regular, monospace;
	}

	.activity-detail__content {
		margin-bottom: 1.5rem;
	}

	.activity-detail__content :is(p, ul, ol, blockquote, pre, figure) {
		margin: 0 0 1rem;
		font-size: 1rem;
		line-height: 1.8;
		color: var(--deep-text);
		word-break: break-word;
	}

	.activity-detail__content :is(h1, h2, h3) {
		margin: 1.5rem 0 0.85rem;
		font-weight: 800;
		color: var(--deep-text);
		line-height: 1.25;
	}

	.activity-detail__content ul,
	.activity-detail__content ol {
		padding-left: 1.4rem;
	}

	.activity-detail__content blockquote {
		padding: 1rem 1.25rem;
		border-left: 3px solid var(--deep-text);
		background: color-mix(in oklch, var(--deep-text) 4%, #fff);
		border-radius: 0.75rem;
	}

	.activity-detail__content pre {
		padding: 1rem 1.125rem;
		background: color-mix(in oklch, var(--deep-text) 5%, #fff);
		border-radius: 0.9rem;
		overflow: auto;
	}

	.activity-detail__content code {
		font-family: ui-monospace, SFMono-Regular, monospace;
	}

	.activity-detail__content .activity-rich-image img {
		width: 100%;
		border-radius: 1rem;
		display: block;
	}

	.activity-detail__content .activity-rich-image figcaption {
		margin-top: 0.6rem;
		font-size: 0.8rem;
		color: var(--content-meta);
		text-align: center;
	}

	.activity-detail__gallery {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1rem;
		margin-bottom: 1.5rem;
	}

	.activity-detail__gallery-item {
		margin: 0;
		border-radius: 1rem;
		overflow: hidden;
		background: color-mix(in oklch, var(--deep-text) 3%, #fff);
	}

	.activity-detail__gallery-item img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.activity-detail__footer {
		padding-top: 1rem;
		border-top: 1px solid var(--deep-text);
	}

	.activity-detail__updated {
		font-size: 0.75rem;
		font-weight: 700;
		color: var(--content-meta);
		font-family: ui-monospace, SFMono-Regular, monospace;
	}

	@media (max-width: 768px) {
		.activity-detail {
			padding: 1.5rem;
		}

		.activity-detail__content :is(p, ul, ol, blockquote, pre, figure) {
			font-size: 0.95rem;
		}
	}
</style>
